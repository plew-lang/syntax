// @Plew/Syntax — the syntax library for user-defined metaprogramming (spec/16).
//
// A macro is a struct implementing `Derive`: it receives the annotated item's
// syntax tree (`DeclAst`) and returns generated Plew source (`String`). The
// `plew gen` runner synthesizes a harness that calls the provided method
// `deriveFromSource` (which lexes+parses the item's source text into a `DeclAst`
// and delegates to the user's `derive`), so the runner stays a version-agnostic
// String↔String machine that never touches the AST types.
//
// M1: the syntactic layer lives here as the one shared core. The AST value types
// (`Kind`/`Tok`/`DeclAst`/… and the parser free functions `lex`/`parseProgramAst`/
// `parseItem`) live at this module root; the parts hold only `impl` blocks (spec/15
// part=impl-only): the lexer's (`part ./Lexer`, shared with the compiler
// frontend), the parser's (`part ./Parser`), and the builder's
// (`part ./Build`). An item's source slice lexes + parses into a `DeclAst`.

// `stringFromBytesUnchecked` (build a String from a byte slice) is used by the parser to
// turn token byte-ranges into name Strings.
import @Std/Core with { stringFromBytesUnchecked }

part ./Lexer
part ./Parser
part ./Build

// A derive is anything that implements a derive interface; `@[X]` is valid when X
// does (spec/16). The single axis is whether the derive carries configuration:
//
// - no config → `Derive` (an `assoc fn derive`, no `self`): invoked bare `@[X]`.
//   A trait can implement it (`impl Hash as Derive` — the deriver lives here in
//   Derive's module, coherent, referencing the ambient `Hash`), as can a no-field
//   struct (`impl Show as Derive`). The annotated item arrives as `TopItemAst`
//   (the deriver `match`es its kind: `Decl` for struct/enum/fn, `Impl`, `Trait`).
// - config → `ParameterizedDerive` (an instance `fn derive`, `self` = the config
//   struct built from the directive args): invoked `@[X(args)]`.
//
// The `plew gen` runner synthesizes a harness that calls `X.derive(input:
// parseItem(...))` (bare) or `<X args/>.derive(input: parseItem(...))` (config) and
// writes the returned String — so the runner stays a version-agnostic String↔String
// machine. (`parseItem` turns the item's source slice into the `TopItemAst`.)
export trait Derive {
    assoc fn derive(input: TopItemAst) -> String
}
export trait ParameterizedDerive {
    fn derive(input: TopItemAst) -> String
}

// Built-in `@[Hash]` derive, dogfooded as a real `Derive` (spec/16). It lives here
// — in `Derive`'s own module — so conforming the ambient `Hash` trait (Prelude) to
// `Derive` is coherent (no orphan, no colliding `struct Hash`). It loads only when
// @Plew/Syntax loads (gen mode + the compiler's own build, where it is dead code);
// normal builds read the committed `.gen.pw`. Generates a field-wise
// `pub impl T as Hash { fn hash[H](hasher: inout H) ... }` for a struct, hashing
// each field via its own `Hash`. (Enum payloads are a follow-up.)
pub impl Hash as Derive {
    assoc fn derive(input: TopItemAst) -> String {
        match input {
            TopItemAst.Decl(val d) => {
                mut val s: Src = newSrc()
                s.put("pub impl ")
                s.put(d.name)
                s.put(" as Hash {\n    fn hash[H](hasher: inout H) where H: Hasher {\n")
                mut val i: U64 = 0
                while i < d.fields.count {
                    s.put("        self.")
                    s.put(d.fields[i].name)
                    s.put(".hash(hasher: inout hasher)\n")
                    i += 1
                }
                s.put("    }\n}\n")
                return s.finish()
            }
            _ => { return "" }
        }
    }
}

// `@[IntTryFrom(sources: [...])]` — generate primitive integer narrowing TryFrom
// witnesses (spec/12). A pure, branch-free renderer: it knows nothing about which
// (target, source) pairs are fallible — the annotated declaration is the TARGET and
// the directive arg lists the SOURCE types (the fallibility decision lives at the
// declaration site, not here). For each source S it emits the SAME body, delegating
// to the target's own `TryFrom[I64]` witness after a lossless widen `source as I64`
// (every sub-64-bit integer widens losslessly to I64). The per-target range/truncate
// knowledge stays in the hand-written `impl T as TryFrom[I64]` bases in Core — O(8),
// not the O(56) pair matrix. Used by the standalone-equivalent dogfood path: Core
// annotates its primitive decls and commits the generated `Core.gen.pw`.
export struct IntTryFrom {
    pub val sources: Array[String]
}
pub impl IntTryFrom { factory }
pub impl IntTryFrom as ParameterizedDerive {
    fn derive(input: TopItemAst) -> String {
        match input {
            TopItemAst.Decl(val d) => {
                mut val s: Src = newSrc()
                mut val i: U64 = 0
                while i < self.sources.count {
                    val src: String = self.sources[i]
                    s.put("pub impl ")
                    s.put(d.name)
                    s.put(" as TryFrom[")
                    s.put(src)
                    s.put("] {\n    type Error = RangeError\n    result[RangeError] factory checked(source: ")
                    s.put(src)
                    s.put(") {\n        return <")
                    s.put(d.name)
                    s.put(".checked source=(source as I64) />\n    }\n}\n")
                    i += 1
                }
                return s.finish()
            }
            _ => { return "" }
        }
    }
}

// ---- AST value types + lexer/parser free functions (the module's public surface;
// at the module root so the parts hold only `impl` blocks — spec/15 part=impl-only) ----

export enum Kind {
    Eof
    Newline
    Int
    Float
    Str
    Char
    Ident
    KwFn
    KwStruct
    KwEnum
    KwMatch
    KwIf
    KwElse
    KwWhile
    KwFor
    KwBreak
    KwContinue
    KwReturn
    KwGive
    KwVal
    KwMut
    KwIn
    KwAs
    KwInout
    KwUnique
    KwDeinit
    KwMove
    KwBorrow
    KwAsync
    KwAwait
    KwExtern
    KwTrue
    KwFalse
    LParen
    RParen
    LBracket
    RBracket
    LBrace
    RBrace
    Comma
    Colon
    Dot
    Eq
    EqEq
    Ne
    Lt
    Le
    Gt
    Ge
    Plus
    Minus
    Star
    Slash
    Percent
    AmpAmp
    PipePipe
    Bang
    Amp
    Pipe
    Caret
    Shl
    Shr
    Tilde
    Arrow
    FatArrow
    SlashGt
    PlusEq
    MinusEq
    StarEq
    SlashEq
    PercentEq
    AmpEq
    PipeEq
    CaretEq
    ShlEq
    ShrEq
    DotDotLt
    DotDotEq
    OptChain
    Hash
    Unknown
}

export struct Tok {
    pub val kind: Kind
    pub val start: U64
    pub val len: U64
}

export struct Lexer {
    pub val bytes: Array[U8]
    pub mut val pos: U64
    pub mut val toks: Array[Tok]
    pub mut val depth: I64
}

fn isDigit(b: U8) -> Bool {
    if b >= '0' {
        if b <= '9' {
            return true
        }
    }
    return false
}

// A digit of the given base (2 / 8 / 10 / 16) — for lexing `0b` / `0o` / `0x`
// literals (spec/02). Hex accepts a-f / A-F; the lower bases accept their digit range.
fn isBaseDigit(b: U8, base: I64) -> Bool {
    if base == 16 {
        if isDigit(b: b) { return true }
        if b >= 'a' { if b <= 'f' { return true } }
        if b >= 'A' { if b <= 'F' { return true } }
        return false
    }
    if base == 8 {
        if b >= '0' { if b <= '7' { return true } }
        return false
    }
    if base == 2 {
        if b == '0' { return true }
        if b == '1' { return true }
        return false
    }
    return isDigit(b: b)
}

fn isAlpha(b: U8) -> Bool {
    if b == '_' {
        return true
    }
    if b >= 'a' {
        if b <= 'z' {
            return true
        }
    }
    if b >= 'A' {
        if b <= 'Z' {
            return true
        }
    }
    return false
}

fn isAlnum(b: U8) -> Bool {
    if isAlpha(b: b) {
        return true
    }
    return isDigit(b: b)
}

export fn rangeEquals(bytes: Array[U8], start: U64, len: U64, kw: String) -> Bool {
    val kb: Array[U8] = kw.bytes()
    if len != kb.count {
        return false
    }
    mut val j: U64 = 0
    while j < len {
        if bytes[start + j] != kb[j] {
            return false
        }
        j += 1
    }
    return true
}

fn identKind(bytes: Array[U8], start: U64, len: U64) -> Kind {
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "fn") {
        return <Kind.KwFn />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "struct") {
        return <Kind.KwStruct />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "enum") {
        return <Kind.KwEnum />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "match") {
        return <Kind.KwMatch />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "if") {
        return <Kind.KwIf />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "else") {
        return <Kind.KwElse />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "while") {
        return <Kind.KwWhile />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "for") {
        return <Kind.KwFor />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "break") {
        return <Kind.KwBreak />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "continue") {
        return <Kind.KwContinue />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "return") {
        return <Kind.KwReturn />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "give") {
        return <Kind.KwGive />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "val") {
        return <Kind.KwVal />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "mut") {
        return <Kind.KwMut />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "in") {
        return <Kind.KwIn />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "as") {
        return <Kind.KwAs />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "inout") {
        return <Kind.KwInout />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "unique") {
        return <Kind.KwUnique />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "deinit") {
        return <Kind.KwDeinit />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "move") {
        return <Kind.KwMove />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "borrow") {
        return <Kind.KwBorrow />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "async") {
        return <Kind.KwAsync />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "await") {
        return <Kind.KwAwait />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "extern") {
        return <Kind.KwExtern />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "true") {
        return <Kind.KwTrue />
    }
    if rangeEquals(bytes: bytes, start: start, len: len, kw: "false") {
        return <Kind.KwFalse />
    }
    return <Kind.Ident />
}

export fn lex(lx: inout Lexer) {
    while lx.pos < lx.bytes.count {
        val b: U8 = lx.at(off: 0)
        if b == ' ' {
            lx.pos += 1
            continue
        }
        if b == '\t' {
            lx.pos += 1
            continue
        }
        if b == '\r' {
            lx.pos += 1
            continue
        }
        if b == '\n' {
            if lx.depth > 0 {
                lx.pos += 1
            } else {
                if lx.lastCanEnd() {
                    if lx.lastWasNewline() {
                        lx.pos += 1
                    } else {
                        lx.emit(k: <Kind.Newline />, start: lx.pos, len: 1)
                    }
                } else {
                    lx.pos += 1
                }
            }
            continue
        }
        if b == '/' {
            if lx.at(off: 1) == '/' {
                while lx.pos < lx.bytes.count {
                    if lx.at(off: 0) == '\n' {
                        break
                    }
                    lx.pos += 1
                }
                continue
            }
            // block comment `/* … */`, nestable (`/* a /* b */ c */`).
            if lx.at(off: 1) == '*' {
                lx.pos += 2
                mut val depth: U64 = 1
                while lx.pos < lx.bytes.count {
                    if depth == 0U64 {
                        break
                    }
                    if lx.at(off: 0) == '/' && lx.at(off: 1) == '*' {
                        depth += 1
                        lx.pos += 2
                    } else {
                        if lx.at(off: 0) == '*' && lx.at(off: 1) == '/' {
                            depth -= 1
                            lx.pos += 2
                        } else {
                            lx.pos += 1
                        }
                    }
                }
                continue
            }
        }
        if isDigit(b: b) {
            val start: U64 = lx.pos
            mut val j: U64 = lx.pos
            // base-prefixed integer literal: `0x…` (hex) / `0o…` (octal) / `0b…`
            // (binary), with `_` digit separators (spec/02). Always an integer.
            if b == '0' {
                if j + 1U64 < lx.bytes.count {
                    val p1: U8 = lx.bytes[j + 1U64]
                    mut val base: I64 = 0
                    if p1 == 'x' { base = 16 }
                    if p1 == 'X' { base = 16 }
                    if p1 == 'o' { base = 8 }
                    if p1 == 'O' { base = 8 }
                    if p1 == 'b' { base = 2 }
                    if p1 == 'B' { base = 2 }
                    if base != 0 {
                        j += 2U64
                        while j < lx.bytes.count {
                            if isBaseDigit(b: lx.bytes[j], base: base) || lx.bytes[j] == '_' {
                                j += 1
                            } else {
                                break
                            }
                        }
                        lx.emit(k: <Kind.Int />, start: start, len: j - start)
                        continue
                    }
                }
            }
            // decimal integer part (allow `_` digit separators)
            while j < lx.bytes.count {
                if isDigit(b: lx.bytes[j]) || lx.bytes[j] == '_' {
                    j += 1
                } else {
                    break
                }
            }
            mut val isFloat: Bool = false
            if j < lx.bytes.count {
                if lx.bytes[j] == 46U8 {
                    if j + 1U64 < lx.bytes.count {
                        if isDigit(b: lx.bytes[j + 1U64]) {
                            isFloat = true
                            j += 1U64
                            while j < lx.bytes.count {
                                if isDigit(b: lx.bytes[j]) || lx.bytes[j] == '_' {
                                    j += 1
                                } else {
                                    break
                                }
                            }
                        }
                    }
                }
            }
            // optional exponent `[eE][+-]?digits` — makes the number a float even
            // without a fractional part (`1e10`, `2E8`, `1.5e-3`). The `e` is consumed
            // only when (optional sign and) a digit follow.
            if j < lx.bytes.count {
                if lx.bytes[j] == 101U8 || lx.bytes[j] == 69U8 {
                    mut val k: U64 = j + 1U64
                    if k < lx.bytes.count {
                        if lx.bytes[k] == 43U8 || lx.bytes[k] == 45U8 {
                            k += 1U64
                        }
                    }
                    if k < lx.bytes.count {
                        if isDigit(b: lx.bytes[k]) {
                            isFloat = true
                            j = k + 1U64
                            while j < lx.bytes.count {
                                if isDigit(b: lx.bytes[j]) || lx.bytes[j] == '_' {
                                    j += 1
                                } else {
                                    break
                                }
                            }
                        }
                    }
                }
            }
            if isFloat {
                lx.emit(k: <Kind.Float />, start: start, len: j - start)
            } else {
                lx.emit(k: <Kind.Int />, start: start, len: j - start)
            }
            continue
        }
        if isAlpha(b: b) {
            val start: U64 = lx.pos
            mut val j: U64 = lx.pos
            while j < lx.bytes.count {
                if isAlnum(b: lx.bytes[j]) {
                    j += 1
                } else {
                    break
                }
            }
            val len: U64 = j - start
            val k: Kind = identKind(bytes: lx.bytes, start: start, len: len)
            lx.emit(k: k, start: start, len: len)
            continue
        }
        if b == '"' {
            val start: U64 = lx.pos
            mut val j: U64 = lx.pos + 1
            while j < lx.bytes.count {
                // a backslash escapes the next byte (so `\"` does not close)
                if lx.bytes[j] == '\\' {
                    j += 2
                    continue
                }
                if lx.bytes[j] == '"' {
                    j += 1
                    break
                }
                j += 1
            }
            lx.emit(k: <Kind.Str />, start: start, len: j - start)
            continue
        }
        if b == '\'' {
            // character literal `'…'` (one scalar; backslash escapes the next byte)
            val start: U64 = lx.pos
            mut val j: U64 = lx.pos + 1
            while j < lx.bytes.count {
                if lx.bytes[j] == '\\' {
                    j += 2
                    continue
                }
                if lx.bytes[j] == '\'' {
                    j += 1
                    break
                }
                j += 1
            }
            lx.emit(k: <Kind.Char />, start: start, len: j - start)
            continue
        }
        val b2: U8 = lx.at(off: 1)
        if b == '.' {
            if b2 == '.' {
                val b3: U8 = lx.at(off: 2)
                if b3 == '<' {
                    lx.emit(k: <Kind.DotDotLt />, start: lx.pos, len: 3)
                    continue
                }
                if b3 == '=' {
                    lx.emit(k: <Kind.DotDotEq />, start: lx.pos, len: 3)
                    continue
                }
            }
            lx.emit(k: <Kind.Dot />, start: lx.pos, len: 1)
            continue
        }
        if b == '=' {
            if b2 == '=' {
                lx.emit(k: <Kind.EqEq />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '>' {
                lx.emit(k: <Kind.FatArrow />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Eq />, start: lx.pos, len: 1)
            continue
        }
        if b == '!' {
            if b2 == '=' {
                lx.emit(k: <Kind.Ne />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Bang />, start: lx.pos, len: 1)
            continue
        }
        if b == '<' {
            if b2 == '=' {
                lx.emit(k: <Kind.Le />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '<' {
                val b3: U8 = lx.at(off: 2)
                if b3 == '=' {
                    lx.emit(k: <Kind.ShlEq />, start: lx.pos, len: 3)
                    continue
                }
                lx.emit(k: <Kind.Shl />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Lt />, start: lx.pos, len: 1)
            continue
        }
        if b == '>' {
            if b2 == '=' {
                lx.emit(k: <Kind.Ge />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '>' {
                val b3: U8 = lx.at(off: 2)
                if b3 == '=' {
                    lx.emit(k: <Kind.ShrEq />, start: lx.pos, len: 3)
                    continue
                }
                lx.emit(k: <Kind.Shr />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Gt />, start: lx.pos, len: 1)
            continue
        }
        if b == '+' {
            if b2 == '=' {
                lx.emit(k: <Kind.PlusEq />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Plus />, start: lx.pos, len: 1)
            continue
        }
        if b == '-' {
            if b2 == '=' {
                lx.emit(k: <Kind.MinusEq />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '>' {
                lx.emit(k: <Kind.Arrow />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Minus />, start: lx.pos, len: 1)
            continue
        }
        if b == '*' {
            if b2 == '=' {
                lx.emit(k: <Kind.StarEq />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Star />, start: lx.pos, len: 1)
            continue
        }
        if b == '/' {
            if b2 == '=' {
                lx.emit(k: <Kind.SlashEq />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '>' {
                lx.emit(k: <Kind.SlashGt />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Slash />, start: lx.pos, len: 1)
            continue
        }
        if b == '%' {
            if b2 == '=' {
                lx.emit(k: <Kind.PercentEq />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Percent />, start: lx.pos, len: 1)
            continue
        }
        if b == '&' {
            if b2 == '&' {
                lx.emit(k: <Kind.AmpAmp />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '=' {
                lx.emit(k: <Kind.AmpEq />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Amp />, start: lx.pos, len: 1)
            continue
        }
        if b == '|' {
            if b2 == '|' {
                lx.emit(k: <Kind.PipePipe />, start: lx.pos, len: 2)
                continue
            }
            if b2 == '=' {
                lx.emit(k: <Kind.PipeEq />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Pipe />, start: lx.pos, len: 1)
            continue
        }
        if b == '^' {
            if b2 == '=' {
                lx.emit(k: <Kind.CaretEq />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Caret />, start: lx.pos, len: 1)
            continue
        }
        if b == '~' {
            lx.emit(k: <Kind.Tilde />, start: lx.pos, len: 1)
            continue
        }
        if b == '#' {
            lx.emit(k: <Kind.Hash />, start: lx.pos, len: 1)
            continue
        }
        if b == '?' {
            if b2 == '.' {
                lx.emit(k: <Kind.OptChain />, start: lx.pos, len: 2)
                continue
            }
            lx.emit(k: <Kind.Unknown />, start: lx.pos, len: 1)
            continue
        }
        if b == '(' {
            lx.emit(k: <Kind.LParen />, start: lx.pos, len: 1)
            lx.depth += 1
            continue
        }
        if b == ')' {
            lx.emit(k: <Kind.RParen />, start: lx.pos, len: 1)
            lx.depth -= 1
            continue
        }
        if b == '[' {
            lx.emit(k: <Kind.LBracket />, start: lx.pos, len: 1)
            lx.depth += 1
            continue
        }
        if b == ']' {
            lx.emit(k: <Kind.RBracket />, start: lx.pos, len: 1)
            lx.depth -= 1
            continue
        }
        if b == '{' {
            lx.emit(k: <Kind.LBrace />, start: lx.pos, len: 1)
            continue
        }
        if b == '}' {
            lx.emit(k: <Kind.RBrace />, start: lx.pos, len: 1)
            continue
        }
        if b == ',' {
            lx.emit(k: <Kind.Comma />, start: lx.pos, len: 1)
            continue
        }
        if b == ':' {
            lx.emit(k: <Kind.Colon />, start: lx.pos, len: 1)
            continue
        }
        lx.emit(k: <Kind.Unknown />, start: lx.pos, len: 1)
    }
    lx.toks.append(<Tok kind=<Kind.Eof /> start=lx.pos len=0 />)
}

export fn kindCode(k: Kind) -> I64 {
    return match k {
        Kind.Eof => 0
        Kind.Newline => 1
        Kind.Int => 2
        Kind.Float => 87
        Kind.Str => 3
        Kind.Char => 5
        Kind.Ident => 4
        Kind.KwFn => 10
        Kind.KwStruct => 11
        Kind.KwEnum => 12
        Kind.KwMatch => 13
        Kind.KwIf => 14
        Kind.KwElse => 15
        Kind.KwWhile => 16
        Kind.KwFor => 17
        Kind.KwBreak => 18
        Kind.KwContinue => 19
        Kind.KwReturn => 20
        Kind.KwGive => 21
        Kind.KwVal => 22
        Kind.KwMut => 23
        Kind.KwIn => 24
        Kind.KwAs => 25
        Kind.KwInout => 26
        Kind.KwUnique => 29
        Kind.KwDeinit => 30
        Kind.KwMove => 31
        Kind.KwBorrow => 32
        Kind.KwAsync => 33
        Kind.KwAwait => 34
        Kind.KwExtern => 35
        Kind.KwTrue => 27
        Kind.KwFalse => 28
        Kind.LParen => 40
        Kind.RParen => 41
        Kind.LBracket => 42
        Kind.RBracket => 43
        Kind.LBrace => 44
        Kind.RBrace => 45
        Kind.Comma => 46
        Kind.Colon => 47
        Kind.Dot => 48
        Kind.Eq => 49
        Kind.EqEq => 50
        Kind.Ne => 51
        Kind.Lt => 52
        Kind.Le => 53
        Kind.Gt => 54
        Kind.Ge => 55
        Kind.Plus => 56
        Kind.Minus => 57
        Kind.Star => 58
        Kind.Slash => 59
        Kind.Percent => 60
        Kind.AmpAmp => 61
        Kind.PipePipe => 62
        Kind.Bang => 63
        Kind.Arrow => 64
        Kind.FatArrow => 65
        Kind.SlashGt => 66
        Kind.PlusEq => 67
        Kind.MinusEq => 68
        Kind.StarEq => 69
        Kind.SlashEq => 70
        Kind.PercentEq => 71
        Kind.DotDotLt => 72
        Kind.DotDotEq => 73
        Kind.Amp => 74
        Kind.Pipe => 75
        Kind.Caret => 76
        Kind.Shl => 77
        Kind.Shr => 78
        Kind.Tilde => 79
        Kind.AmpEq => 80
        Kind.PipeEq => 81
        Kind.CaretEq => 82
        Kind.ShlEq => 83
        Kind.ShrEq => 84
        Kind.OptChain => 85
        Kind.Hash => 86
        Kind.Unknown => 99
    }
}

export struct Span {
    pub val start: U64
    pub val end: U64
}

// A type expression. `Array[U8]` -> name="Array", args=[U8]; a bare `T` ->
// name="T", args=[]. (Function types `fn(...)->T` are an additive follow-up.)
export struct TypeAst {
    pub val name: String
    pub val args: Array[TypeAst]
    pub val span: Span
    // `Person#Ext` (spec/09): an extension-view refinement of the type. "" for a
    // plain type. A zero-cost view (same runtime layout) that selects which
    // extension's methods/witnesses resolve; treated as an invariant type detail.
    pub val extView: String = ""
    // `any P` (spec/08): an existential — a type-erased value of any concrete type
    // conforming to trait `name`. false for a plain type. Runtime layout is a fat
    // pointer `{ data, vtable }` (vs the plain type's own layout), so this is part
    // of type identity, not a zero-cost view.
    pub val isAny: Bool = false
    // binding labels parallel to `args` (spec/08 existential formation / spec/12
    // associated-type binding): for `any Add[I32, Output=I32]`, args=[I32, I32] and
    // argLabels=["", "Output"] — "" marks a positional type argument, a non-empty
    // label marks a named associated-type / type-parameter binding `Name=Type`.
    // Empty (or all "") for an ordinary generic type like `Array[I32]`.
    pub val argLabels: Array[String] = []
    // a labelled anonymous record type `(x: I32, y: I32)` (spec/02): a structural,
    // nameless record. `args` holds the field types and `argLabels` the field names
    // (parallel). `name` is empty. The type lowers to a synthetic struct keyed by its
    // sorted (name, type) set, so two records with the same fields are the same type.
    pub val isRecord: Bool = false
}

// A struct field / enum-variant payload field. For a variant payload field,
// `isMut` is false and `vis` is 0 (variants take no modifiers). `vis`: 0 = private,
// 1 = pub(get), 2 = pub (matches the compiler's encoding). A default value
// (`val x: T = expr`) is flagged by `hasDefault` and surfaced in `defaultVal` (an
// `emptyExpr()` placeholder when absent).
export struct FieldAst {
    pub val name: String
    pub val ty: TypeAst
    pub val isMut: Bool
    pub val vis: U64
    pub val hasDefault: Bool
    pub val defaultVal: ExprAst
    pub val span: Span
}

// An enum variant. `fields` is the record payload `V(x: I32, y: I32)`; empty for a
// payload-less variant `V`.
export struct VariantAst {
    pub val name: String
    pub val fields: Array[FieldAst]
    pub val span: Span
}

// A function parameter. Access modes (spec/03): `inout`/`move`/`borrow`. A
// label-suppressed `name~: T` sets `noLabel`. A default value (`name: T = expr`) is
// flagged by `hasDefault` and surfaced in `defaultVal` (`emptyExpr()` when absent).
export struct ParamAst {
    pub val name: String
    pub val ty: TypeAst
    pub val isInout: Bool
    pub val isMove: Bool
    pub val isBorrow: Bool
    pub val noLabel: Bool
    pub val hasDefault: Bool
    pub val defaultVal: ExprAst
    pub val span: Span
}

// Which kind of declaration a `DeclAst` is.
export enum DeclKind {
    Struct
    Enum
    Func
}

// The parsed top-level item a macro is attached to. A tagged record: `kind`
// selects struct / enum / fn, and the kind-specific fields below are populated
// accordingly (the others stay empty). A `Derive` switches on `kind` and reads
// the relevant fields.
//
// (This is a flat tagged struct rather than an `enum DeclAst { Struct(StructDecl)
// … }` because the C backend does not yet emit nominal bodies in dependency
// order — an enum holding a struct payload by value would forward-reference an
// incomplete type. A struct holding an enum tag + struct fields by value is fine.
// Restoring the enum form is a follow-up once the backend topologically orders
// nominal bodies.)
export struct DeclAst {
    pub val kind: DeclKind
    pub val name: String
    // the NAME token's span (original coordinates). Distinct from `span` (the whole
    // declaration, keyword..closing brace). The compiler frontend needs the name's
    // ORIGINAL offset for a `fn`/`struct`/`enum` declaration so `moduleOf` (cross-
    // module visibility) attributes it to the right module.
    pub val nameSpan: Span
    pub val typeParams: Array[String]
    pub val span: Span
    // struct (`kind == Struct`)
    pub val isUnique: Bool
    pub val fields: Array[FieldAst]
    // struct `deinit { ... }` (spec/03): the parsed block, flagged by `hasDeinit`.
    // A macro can read it; the compiler lowers it to a synthetic `Type_deinit` method.
    pub val hasDeinit: Bool
    pub val deinitBody: BlockAst
    // enum (`kind == Enum`)
    pub val variants: Array[VariantAst]
    // fn (`kind == Func`)
    pub val params: Array[ParamAst]
    pub val hasRet: Bool
    pub val ret: TypeAst
    // `async fn` (spec/14): the function is a stackless state machine returning a
    // Promise. Default false. (The caller of a top-level `async fn` consumes the
    // `async` keyword and threads it in.)
    pub val isAsync: Bool
    // `where T: A + B, U: C` trait bounds (spec/08), as parallel name lists: each
    // atom (one trait per `+`/`,` expansion) is a (param, trait) pair. Empty for an
    // unconstrained function. A macro reads them; the compiler lowers them to
    // FuncBound records.
    pub val whereParams: Array[String]
    pub val whereTraits: Array[String]
    // fn body (`kind == Func`): the parsed `{ ... }` block (empty for struct/enum
    // and for a body-less signature). Lets a macro read/transform a function body.
    pub val body: BlockAst
    // `defaultExtension #A #B` declared in a struct/enum body (spec/09): the names
    // of extensions whose methods join this type's bare surface. Empty otherwise.
    pub val defaultExts: Array[String] = []
}

// An empty type expression (placeholder for a missing/absent type position).
export fn emptyTypeAst() -> TypeAst {
    return <TypeAst name="" args=[] span=<Span start=0 end=0 /> />
}

// Which kind of member a `MemberAst` is inside an `impl` block (spec/07,08).
export enum MemberKind {
    Method      // `[inout|move|borrow] fn` / `async [move] fn` — has self
    AssocFn     // `assoc fn` — namespaced on the type, no self
    Deinit      // `deinit { ... }` — synthetic Type_deinit method
    AssocType   // `type Item = Concrete` — conformance's associated-type binding
    Factory     // `factory` — publishes the default memberwise factory (spec/05): in
                // a `pub impl T { }` it makes `<T …/>` constructible from other modules
}

// A member of an `impl` block. A tagged record (`kind` selects the shape; the
// kind-specific fields below are populated accordingly). For Method/AssocFn it is
// a function signature + body (or a `via real` alias); for Deinit just a body; for
// AssocType a name + bound type.
export struct MemberAst {
    pub val kind: MemberKind
    pub val name: String
    pub val nameSpan: Span
    pub val typeParams: Array[String]
    pub val params: Array[ParamAst]
    pub val hasRet: Bool
    pub val ret: TypeAst
    pub val whereParams: Array[String]
    pub val whereTraits: Array[String]
    // `async fn` method (spec/14). `selfInout` = `inout fn` (mutable self),
    // `selfMove` = `move fn`/`async move fn` (consuming self). A plain/`borrow fn`
    // has both false.
    pub val isAsync: Bool
    pub val selfInout: Bool
    pub val selfMove: Bool
    // `fn req(...) -> T via real` (spec/08): witnesses a requirement by aliasing an
    // existing method `real` (no body). `viaName` is `real`.
    pub val isVia: Bool
    pub val viaName: String
    // Method/AssocFn/Deinit body (empty for `via` and AssocType).
    pub val body: BlockAst
    // AssocType's bound type `type Item = <assocTy>`.
    pub val assocTy: TypeAst
    // a custom `factory [name](params) { … }` (spec/05): lowered as an AssocFn whose
    // return type is the impl's type (the implicit `Self`). Invoked via `<Type.name …/>`.
    pub val isFactory: Bool = false
    // a fallible factory's wrapper (spec/05): 0 = plain (`-> Self`), 1 = `optional`
    // (`-> Optional[Self]`), 2 = `result[E]` (`-> Result[Self, E]`). factoryErr is the
    // error type `E` for kind 2.
    pub val factoryKind: U64 = 0
    pub val factoryErr: TypeAst = emptyTypeAst()
}

// A body-less function signature: a trait requirement (`fn req(...) -> T`) or an
// `extern "plew-intrinsic"` declaration (spec/08,15). `name`/`nameSpan` keep the
// original coordinates (an extern fn name feeds moduleOf for cross-module calls).
export struct SigAst {
    pub val name: String
    pub val nameSpan: Span
    pub val typeParams: Array[String]
    pub val params: Array[ParamAst]
    pub val hasRet: Bool
    pub val ret: TypeAst
    pub val isAssoc: Bool
    // `inout fn` requirement (spec/08): the method mutates `self`. Conformance still
    // matches by selector, not self-mode, but the existential dispatch needs it to
    // pass the boxed self by pointer (a mutating method on `any P` — `inout next()`).
    pub val selfInout: Bool = false
}

// A `trait Name [: Super + ...] { requirements }` declaration (spec/08). The body
// holds only requirement signatures (no bodies) + associated-type names.
export struct TraitAst {
    pub val name: String
    pub val nameSpan: Span
    // trait type parameters `trait Add[Rhs]` (spec/12): the right-operand-type
    // parameter of operator traits and any other trait type args. Empty for a
    // non-parameterized trait (Eq/Ord/Hasher).
    pub val typeParams: Array[String]
    pub val supertraits: Array[String]
    pub val reqs: Array[SigAst]
    pub val assocTypes: Array[String]
    pub val span: Span
}

// An `extern "abi" { fn ... ; struct ... }` block (spec/15 core-library boundary).
// `abiOk` is true iff the ABI string is `"plew-intrinsic"` (the only one accepted);
// `abiSpan` points at the `extern` keyword for the error. `fns` are body-less
// intrinsic signatures; `structNames`/`structSpans` are opaque lang-item types.
export struct ExternAst {
    pub val abiOk: Bool
    // true iff the ABI is the C ABI (`extern(c)` — spec/15 FFI). Distinguishes a
    // foreign-C block (raw symbol names, emitted prototypes) from the intrinsic
    // floor (`extern(plewIntrinsic)` / legacy `"plew-intrinsic"`, runtime `plew_*`).
    pub val abiC: Bool = false
    pub val abiSpan: Span
    pub val fns: Array[SigAst]
    pub val structNames: Array[String]
    // per-struct generic type-parameter names (parallel to structNames; empty = a
    // non-generic opaque type). Lets a generic opaque intrinsic — `struct Buffer[T]` —
    // be registered as a real generic struct (so its `Buffer[E]` uses are generic
    // instances dispatched uniformly), distinct from non-generic `struct Ref`.
    pub val structTypeParams: Array[Array[String]] = []
    // per-struct source span covering `struct Name` (the whole item), so a `@[...]`
    // derive on an extern struct can feed `parseItem` the item's source (spec/16).
    pub val structSpans: Array[Span]
    // per-struct `@[...]` directive (parallel to structNames; empty `reqs` = none).
    // Lets a derive macro target an opaque lang-item / FFI type declared in an extern
    // block (spec/15,16) — e.g. `@[IntTryFrom(...)] struct I8`.
    pub val structDirectives: Array[DirectiveAst]
    pub val span: Span
}

// An `[pub] impl[T] Recv [as Trait] [where ...] { members }` block (spec/07,08).
// `recvType` carries the receiver type (its head name is the type the members are
// registered on; the `[T]` args are redundant with `implParams`).
export struct ImplAst {
    pub val recvType: TypeAst
    pub val implParams: Array[String]
    pub val isTraitImpl: Bool
    pub val traitName: String
    // trait type arguments `impl V as Add[V]` (spec/12): bind the trait's type
    // parameters to concrete types. Empty for a bare `impl V as Trait`.
    pub val traitArgs: Array[TypeAst]
    // impl-level `where I: Trait` (spec/08): folded into every member's bounds.
    pub val whereParams: Array[String]
    pub val whereTraits: Array[String]
    pub val isPub: Bool
    pub val members: Array[MemberAst]
    pub val span: Span
    // the enclosing `extension Name { ... }` (spec/09), "" for a bare impl. An
    // extension impl's members do not join bare resolution; they are reached only
    // through a call-site `value#Name.member` view.
    pub val extName: String = ""
}

// An `import <path> [with { name [as Q], ... }]` statement (spec/15). `pathSpan` is
// the full contiguous path text (`@Std/Io` / `./Foo` / `/Models/User`) in original
// coordinates — the loader resolves it to a file (parse-driven loading). `segSpan`
// is the last path segment (the submodule). Each `with` name keeps its original span
// (the importing-side occurrence — feeds moduleOf for the importing module).
export struct ImportAst {
    pub val pathSpan: Span
    pub val segSpan: Span
    pub val isImport: Bool
    pub val names: Array[String]
    pub val nameSpans: Array[Span]
    // a path-level alias `import <path> as F` (spec/15): binds the namespace to `F`
    // instead of the last path segment. Empty span when absent.
    pub val aliasSpan: Span = <Span start=0 end=0 />
    // per-name aliases for `with { Bar as Q }` (spec/15), parallel to `names`. An
    // empty span means the name is imported under its own name.
    pub val nameAliasSpans: Array[Span] = []
    pub val span: Span
}

// One `@[Name(label: expr, ...)]` derive request: the macro/derive name + its
// directive arguments (each a labelled value that becomes a field on the constructed
// macro struct). `nameSpan` keeps the original coordinates (text-matched downstream).
export struct DeriveReqAst {
    pub val name: String
    pub val nameSpan: Span
    pub val args: Array[MakeFieldAst]
}

// An `@[Eq, Ord, Name(a: 32), ...]` directive (spec/16): the comma-separated derive
// requests applied to the next type declaration.
export struct DirectiveAst {
    pub val reqs: Array[DeriveReqAst]
}

// A top-level item of a program (spec/15). The shared `parseProgramAst` returns a
// list of these; the compiler frontend lowers each (Codegen/Lower.pw) into its arena
// or Comp state, and follows `Import` nodes to load further files. `Export` wraps the
// exported inner item (recursive — auto-boxed); `ReExport` is an `export <path> with
// { … }` (a pure forwarding re-export, spec/15): it carries the same `ImportAst` an
// `import` would (path + selected names + aliases) so the loader can load the
// forwarded module and the frontend can republish its names — but unlike `import` it
// binds NOTHING locally (forwarding only). `imp.isImport` is true (it resolves a fresh
// module like an import); the `ReExport` wrapper is what marks it as forward-only.
export enum TopItemAst {
    Decl(d: DeclAst)
    Impl(im: ImplAst)
    Trait(t: TraitAst)
    Extern(e: ExternAst)
    Import(imp: ImportAst)
    Export(inner: TopItemAst)
    ReExport(imp: ImportAst)
    Directive(dir: DirectiveAst)
    // a module-level variable (spec/15): `val x = e` / `mut val x = e`. The payload
    // is the same `StmtAst.Let` the local-binding parser produces (name / optional
    // type / initializer); the frontend lowers it to a `Comp.globals` entry and the
    // backend emits an LLVM global initialized once before `main` runs.
    GlobalVal(s: StmtAst)
    // a named type (spec/10): `newtype Meter = F64`. `name` is the distinct type; `ty`
    // is the underlying. Same representation as the underlying (a zero-cost `as`
    // re-tag), but a distinct type identity that inherits the underlying's methods.
    NewType(name: String, ty: TypeAst, isPub: Bool, span: Span)
}

export struct ArgAst {
    pub val label: String
    pub val hasLabel: Bool
    pub val isInout: Bool
    pub val value: ExprAst
    pub val span: Span
}

// A field binding in a JSX construction `<T field=expr />`.
export struct MakeFieldAst {
    pub val name: String
    pub val value: ExprAst
    pub val span: Span
}

// One field bind inside a pattern. `field` is the variant/struct field read;
// `name` is the local introduced (equal for punning `val x`).
export struct BindAst {
    pub val field: String
    pub val name: String
    pub val span: Span
}

// A match pattern (everything before `=>`): wildcard `_`, an enum variant
// `E.V(binds)`, a struct destructure `S { binds }`, or a bare literal `0`/`"x"`/
// `true`/`-1` (isLiteral; `lit` is the literal expression — spec/11). A literal
// match desugars in lowering to a temp-bound `==` if/else chain, so the arena
// never sees a literal pattern.
export struct PatternAst {
    pub val isWildcard: Bool
    pub val isStruct: Bool
    pub val typeName: String
    pub val variant: String
    pub val binds: Array[BindAst]
    pub val isLiteral: Bool = false
    pub val lit: ExprAst = emptyExpr()
    // a capture binding `val x` — a named wildcard that binds the whole scrutinee to
    // `captureName` (spec/11). isWildcard is also true; captureName is "" for a plain `_`.
    pub val captureName: String = ""
    pub val span: Span
}

// One match arm: a pattern and a body block (a single-`give` block in expression
// position). `match` arms have NO guards (spec/11): refinement is done by binding
// then a nested `match`, or a preceding `if`/`guard` condition chain — this keeps
// exhaustiveness purely structural.
export struct MatchArmAst {
    pub val pattern: PatternAst
    pub val body: BlockAst
    pub val span: Span
}

// A `{ ... }` block: a sequence of statements.
export struct BlockAst {
    pub val stmts: Array[StmtAst]
}

// An expression. `op` fields carry the operator's lexer kind code (kindCode).
export enum ExprAst {
    IntLit(value: U64, isBool: Bool, tySuffix: String, span: Span)
    FloatLit(text: String, tySuffix: String, span: Span)
    StrLit(raw: String, span: Span)
    Ident(name: String, span: Span)
    Unary(op: I64, operand: ExprAst, span: Span)
    Binary(op: I64, lhs: ExprAst, rhs: ExprAst, span: Span)
    Call(name: String, args: Array[ArgAst], span: Span)
    Field(base: ExprAst, name: String, span: Span)
    // `nameSpan` is the method name's own source span (the whole-call `span` starts at
    // the receiver), needed to recover the name's original offset for a namespace call
    // `Namespace.fn(args)` (spec/15).
    Method(recv: ExprAst, name: String, nameSpan: Span, args: Array[ArgAst], span: Span)
    // `recv#Ext.name(args)` (spec/09): a method call through an extension view.
    // `src` is the extension (or trait) name selecting the method source.
    ExtMethod(recv: ExprAst, src: String, name: String, args: Array[ArgAst], span: Span)
    // `recv#Ext` / `recv#!Ext` (spec/09): a zero-cost value re-view. `strip=false`
    // selects extension `src` (the static type gains the `#Ext` view); `strip=true`
    // removes it (`#!Ext`, the "super" form — a following `.method()` resolves the
    // shadowed bare method). The value is unchanged either way.
    ExtView(recv: ExprAst, src: String, strip: Bool, span: Span)
    Index(base: ExprAst, index: ExprAst, span: Span)
    Make(typeName: String, typeArgs: Array[TypeAst], variant: String, isEnum: Bool, fields: Array[MakeFieldAst], span: Span)
    ArrayLit(elems: Array[ExprAst], span: Span)
    DictLit(keys: Array[ExprAst], vals: Array[ExprAst], span: Span)
    // a labelled anonymous record literal `(x: 1, y: 2)` (spec/02). `fields` reuses
    // MakeFieldAst (label + value). The field types come from each value (or the
    // context type); it lowers to a synthetic struct construction.
    RecordLit(fields: Array[MakeFieldAst], span: Span)
    Cast(operand: ExprAst, ty: TypeAst, span: Span)
    MatchExpr(scrut: ExprAst, arms: Array[MatchArmAst], span: Span)
    IfExpr(cond: ExprAst, thenBlk: BlockAst, elseBlk: BlockAst, span: Span)
    OptChain(base: ExprAst, member: String, span: Span)
    Try(operand: ExprAst, span: Span)
    Arrow(base: ExprAst, name: String, span: Span)
    Closure(params: Array[ParamAst], hasRet: Bool, ret: TypeAst, body: BlockAst, span: Span)
    Move(operand: ExprAst, isBorrow: Bool, span: Span)
    Await(operand: ExprAst, span: Span)
}

// A statement.
export enum StmtAst {
    Let(mutable: Bool, name: String, hasTy: Bool, ty: TypeAst, init: ExprAst, span: Span)
    Assign(op: I64, target: ExprAst, value: ExprAst, span: Span)
    ExprStmt(expr: ExprAst, span: Span)
    Return(value: ExprAst, hasValue: Bool, span: Span)
    If(cond: ExprAst, thenBlk: BlockAst, elseBlk: BlockAst, hasElse: Bool, span: Span)
    While(cond: ExprAst, body: BlockAst, span: Span)
    For(varName: String, varTy: TypeAst, hasVarTy: Bool, isRange: Bool, inclusive: Bool, iter: ExprAst, rangeHi: ExprAst, body: BlockAst, isStruct: Bool, patType: String, binds: Array[BindAst], span: Span)
    Match(scrut: ExprAst, arms: Array[MatchArmAst], span: Span)
    Panic(msg: ExprAst, span: Span)
    Give(value: ExprAst, span: Span)
    Break(span: Span)
    Continue(span: Span)
    // a record-destructuring binding `(val x, val y) = expr` (spec/02,03): each bind is
    // a field of the record value `init`. Punning `(val x)` is field=name=x; explicit
    // `(a: val x)` is field=a name=x. Lowers to a temp binding plus one `val` per field.
    Destructure(binds: Array[BindAst], init: ExprAst, span: Span)
}

// A placeholder expression (an absent value position, e.g. `return` with no value).
export fn emptyExpr() -> ExprAst {
    return <ExprAst.IntLit value=0 isBool=false tySuffix="" span=<Span start=0 end=0 /> />
}

// An empty block.
export fn emptyBlock() -> BlockAst {
    return <BlockAst stmts=[] />
}

export struct P {
    pub val bytes: Array[U8]
    pub val toks: Array[Tok]
    pub mut val pos: U64
    pub val base: U64
    // recoverable error state: the parser keeps going (for macro robustness) but
    // records the first syntax error (original-coordinate offset + message). The
    // compiler frontend checks `hasErr` after a parse and reports it loudly; a macro
    // can inspect it or ignore it.
    pub mut val hasErr: Bool = false
    pub mut val errOff: U64 = 0
    pub mut val errMsg: String = ""
}

// Does the current token match keyword text `kw` (an Ident like `pub`/`export`/
// `get`/`where`)? `export`/`pub`/`where` are contextual identifiers, not Kinds.
fn curIs(p: inout P, kw: String) -> Bool {
    match p.curKind() {
        Kind.Ident => {
            val t: Tok = p.curTok()
            return rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: kw)
        }
        _ => { return false }
    }
}

// Skip a balanced `[ ... ]` group (current token must be the opening `[`).
fn skipBracketGroup(p: inout P) {
    mut val depth: I64 = 0
    while true {
        match p.curKind() {
            Kind.LBracket => {
                depth += 1
                p.advance()
            }
            Kind.RBracket => {
                depth -= 1
                p.advance()
                if depth == 0 {
                    break
                }
            }
            Kind.Eof => { break }
            _ => { p.advance() }
        }
    }
}

// Skip leading newlines, the `@[...]` directive(s), and an `export` modifier, so
// the cursor lands on the item keyword (`struct`/`enum`/`fn`/`unique`).
fn skipLeading(p: inout P) {
    while true {
        match p.curKind() {
            Kind.Newline => { p.advance() }
            Kind.Unknown => {
                // a directive: `@` lexes as Unknown; skip it and its `[...]`.
                p.advance()
                match p.curKind() {
                    Kind.LBracket => { skipBracketGroup(p: inout p) }
                    _ => {}
                }
            }
            Kind.Ident => {
                if curIs(p: inout p, kw: "export") {
                    p.advance()
                } else {
                    break
                }
            }
            _ => { break }
        }
    }
}

// A type expression `Name` or `Name[Arg, ...]`. Mirrors parseTypeTok's nominal
// path; a function type `fn(label: T, ...) -> R` is modeled as name="fn" with
// args = [R, T1, T2, ...] (labels/`inout` dropped — they aren't part of the C
// calling convention), mirroring the compiler's parseTypeTok. The current token is
// the type head.
fn parseType(p: inout P) -> TypeAst {
    // an existential `any P` (spec/08): the lowercase `any` (never a type name —
    // types are PascalCase) followed by a trait type. Parse the trait type and tag
    // it `isAny`. Unambiguous because `any` cannot head a real type.
    if curIs(p: inout p, kw: "any") {
        if p.peekKind(off: 1) == <Kind.Ident /> {
            val anyStart: U64 = p.base + p.curTok().start
            p.advance()
            val inner: TypeAst = parseType(p: inout p)
            return <TypeAst name=inner.name args=inner.args span=<Span start=anyStart end=p.prevEnd() /> extView=inner.extView isAny=true argLabels=inner.argLabels />
        }
    }
    // a labelled anonymous record type `(x: I32, y: I32)` / unit `()` (spec/02): a
    // structural record. Fields are `label: Type` pairs; `name` stays empty and the
    // field names/types ride in argLabels/args (isRecord marks it).
    match p.curKind() {
        Kind.LParen => {
            val recStart: U64 = p.base + p.curTok().start
            p.advance()
            mut val fieldTypes: Array[TypeAst] = []
            mut val fieldNames: Array[String] = []
            while true {
                match p.curKind() {
                    Kind.RParen => { p.advance()  break }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    _ => {
                        val labelTok: Tok = p.curTok()
                        val label: String = p.text(t: labelTok)
                        p.advance()
                        match p.curKind() {
                            Kind.Colon => { p.advance() }
                            _ => { p.fail(off: p.base + p.curTok().start, msg: "an anonymous record field needs a `label: Type` (every field is labelled)") }
                        }
                        fieldNames.append(label)
                        fieldTypes.append(parseType(p: inout p))
                    }
                }
            }
            return <TypeAst name="" args=fieldTypes span=<Span start=recStart end=p.prevEnd() /> argLabels=fieldNames isRecord=true />
        }
        _ => {}
    }
    val head: Tok = p.curTok()
    val name: String = p.text(t: head)
    val sStart: U64 = p.base + head.start
    p.advance()
    match head.kind {
        Kind.KwFn => {
            mut val fparams: Array[TypeAst] = []
            // parameter labels (spec/04: labels are part of a function type's identity);
            // "" for an unlabeled position. Captured parallel to fparams.
            mut val flabels: Array[String] = []
            match p.curKind() {
                Kind.LParen => { p.advance() }
                _ => {}
            }
            while true {
                match p.curKind() {
                    Kind.RParen => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    _ => {
                        // optional `label:` (or `label~:`) before the type.
                        mut val lbl: String = ""
                        match p.curKind() {
                            Kind.Ident => {
                                if p.peekKind(off: 1) == <Kind.Colon /> {
                                    lbl = p.text(t: p.curTok())
                                    p.advance()
                                    p.advance()
                                }
                            }
                            _ => {}
                        }
                        match p.curKind() {
                            Kind.KwInout => { p.advance() }
                            _ => {}
                        }
                        flabels.append(lbl)
                        fparams.append(parseType(p: inout p))
                    }
                }
            }
            mut val fret: TypeAst = emptyTypeAst()
            match p.curKind() {
                Kind.Arrow => {
                    p.advance()
                    fret = parseType(p: inout p)
                }
                _ => {}
            }
            mut val fargs: Array[TypeAst] = []
            fargs.append(fret)
            // argLabels parallel to fargs: slot 0 is the return type (no label, ""),
            // slots 1.. carry each parameter's label.
            mut val fargLabels: Array[String] = []
            fargLabels.append("")
            mut val fk: U64 = 0
            while fk < fparams.count {
                fargs.append(fparams[fk])
                fargLabels.append(flabels[fk])
                fk += 1
            }
            return <TypeAst name=name args=fargs argLabels=fargLabels span=<Span start=sStart end=p.prevEnd() /> />
        }
        _ => {}
    }
    mut val args: Array[TypeAst] = []
    // binding labels parallel to args: a named associated-type / type-parameter
    // binding `Name=Type` (spec/08,12 — used by `any P[Item=I32]`) records its name;
    // an ordinary positional type argument records "".
    mut val argLabels: Array[String] = []
    match p.curKind() {
        Kind.LBracket => {
            p.advance()
            while true {
                match p.curKind() {
                    Kind.RBracket => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    _ => {
                        // a named binding `Name = Type` (an Ident immediately followed
                        // by `=`): record the label and parse the bound type.
                        mut val lbl: String = ""
                        match p.curKind() {
                            Kind.Ident => {
                                if p.peekKind(off: 1) == <Kind.Eq /> {
                                    lbl = p.text(t: p.curTok())
                                    p.advance()
                                    p.advance()
                                }
                            }
                            _ => {}
                        }
                        args.append(parseType(p: inout p))
                        argLabels.append(lbl)
                    }
                }
            }
        }
        _ => {}
    }
    // an extension-view refinement `Person#Ext` (spec/09): the head type plus a
    // selected extension. Only a single `#Name` for now (chained `#A#B` later).
    mut val extView: String = ""
    match p.curKind() {
        Kind.Hash => {
            p.advance()
            extView = p.text(t: p.curTok())
            p.advance()
        }
        _ => {}
    }
    return <TypeAst name=name args=args span=<Span start=sStart end=p.prevEnd() /> extView=extView argLabels=argLabels />
}

// Parse a `newtype Name = Underlying` declaration (spec/10). The contextual `newtype`
// has already been confirmed by the caller; consume it, the name, `=`, and the type.
fn parseNewtypeAst(p: inout P, isPub: Bool) -> TopItemAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val name: String = p.text(t: p.curTok())
    p.advance()
    match p.curKind() {
        Kind.Eq => { p.advance() }
        _ => { p.fail(off: p.base + p.curTok().start, msg: "a newtype declaration is `newtype Name = Underlying`") }
    }
    val ty: TypeAst = parseType(p: inout p)
    return <TopItemAst.NewType name=name ty=ty isPub=isPub span=<Span start=sStart end=p.prevEnd() /> />
}

// An optional generic parameter list `[T, U]` -> the parameter names. Capability
// markers (noLocal/allowUnique) precede the name and are dropped (the name is the
// last ident of an entry), mirroring parseTypeParams.
fn parseTypeParamNames(p: inout P) -> Array[String] {
    mut val ps: Array[String] = []
    match p.curKind() {
        Kind.LBracket => {
            p.advance()
            while true {
                match p.curKind() {
                    Kind.RBracket => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    Kind.Colon => {
                        // inline trait constraint `[T: Trait]` (spec/06: not allowed —
                        // constraints go in a `where` clause). Reject loudly.
                        p.fail(off: p.base + p.curTok().start, msg: "inline trait constraint is not allowed in `[...]`; use a `where` clause")
                        p.advance()
                    }
                    Kind.Ident => {
                        mut val name: String = ""
                        while true {
                            match p.curKind() {
                                Kind.Ident => {
                                    name = p.text(t: p.curTok())
                                    p.advance()
                                }
                                _ => { break }
                            }
                        }
                        ps.append(name)
                    }
                    _ => { p.advance() }
                }
            }
        }
        _ => {}
    }
    return ps
}

// A struct field: `[pub[(get)]] [mut] val name [: Type] [= expr]`. The cursor is
// at the field start (caller has skipped newlines and ruled out `}`/`deinit`).
fn parseStructField(p: inout P) -> FieldAst {
    val fStart: U64 = p.base + p.curTok().start
    mut val vis: U64 = 0
    if curIs(p: inout p, kw: "pub") {
        p.advance()
        vis = 2
        match p.curKind() {
            Kind.LParen => {
                p.advance()
                if curIs(p: inout p, kw: "get") {
                    vis = 1
                }
                match p.curKind() {
                    Kind.Ident => { p.advance() }
                    _ => {}
                }
                match p.curKind() {
                    Kind.RParen => { p.advance() }
                    _ => {}
                }
            }
            _ => {}
        }
    }
    mut val isMut: Bool = false
    match p.curKind() {
        Kind.KwMut => {
            p.advance()
            isMut = true
        }
        _ => {}
    }
    match p.curKind() {
        Kind.KwVal => { p.advance() }
        _ => {}
    }
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    p.advance()
    mut val ty: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Colon => {
            p.advance()
            ty = parseType(p: inout p)
        }
        _ => {}
    }
    mut val hasDefault: Bool = false
    mut val defaultVal: ExprAst = emptyExpr()
    match p.curKind() {
        Kind.Eq => {
            p.advance()
            defaultVal = parseExprAst(p: inout p)
            hasDefault = true
        }
        _ => {}
    }
    return <FieldAst name=name ty=ty isMut=isMut vis=vis hasDefault=hasDefault defaultVal=defaultVal span=<Span start=fStart end=p.prevEnd() /> />
}

// A struct declaration. The cursor is at `struct` (the `unique` modifier, if any,
// is already consumed and passed as `isUnique`).
export fn parseStructDecl(p: inout P, isUnique: Bool) -> DeclAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    val typeParams: Array[String] = parseTypeParamNames(p: inout p)
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val fields: Array[FieldAst] = []
    mut val hasDeinit: Bool = false
    mut val deinitBody: BlockAst = emptyBlock()
    mut val defaultExts: Array[String] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.Comma => {
                // struct fields are newline-separated (spec/05); a comma would be
                // swallowed as an empty-named field, so reject it loudly.
                p.fail(off: p.base + p.curTok().start, msg: "struct fields are separated by newlines, not commas")
                p.advance()
            }
            Kind.KwDeinit => {
                p.advance()
                p.skipNewlines()
                deinitBody = parseBlockAst(p: inout p)
                hasDeinit = true
            }
            _ => {
                // struct fields are newline-separated (spec/05); a `;` would be
                // parsed as an empty-named phantom field, so reject it loudly (like a
                // comma) instead of silently widening the struct.
                if p.text(t: p.curTok()) == ";" {
                    p.fail(off: p.base + p.curTok().start, msg: "struct fields are separated by newlines, not `;`")
                    p.advance()
                } else {
                if curIs(p: inout p, kw: "defaultExtension") {
                    // `defaultExtension #A #B` (spec/09): name the extensions whose
                    // methods join this type's bare surface. Chained `#A#B` or
                    // space-separated; collect each `#Name`.
                    p.advance()
                    mut val moreExt: Bool = true
                    while moreExt {
                        match p.curKind() {
                            Kind.Hash => {
                                p.advance()
                                defaultExts.append(p.text(t: p.curTok()))
                                p.advance()
                            }
                            _ => { moreExt = false }
                        }
                    }
                } else {
                    fields.append(parseStructField(p: inout p))
                }
                }
            }
        }
    }
    return <DeclAst kind=<DeclKind.Struct /> name=name nameSpan=nameSpan typeParams=typeParams span=<Span start=sStart end=p.prevEnd() /> isUnique=isUnique fields=fields hasDeinit=hasDeinit deinitBody=deinitBody variants=[] params=[] hasRet=false ret=emptyTypeAst() isAsync=false whereParams=[] whereTraits=[] body=emptyBlock() defaultExts=defaultExts />
}

// An enum variant payload field `name: Type` (no modifiers). The cursor is at the
// field name.
fn parseVariantField(p: inout P) -> FieldAst {
    val fStart: U64 = p.base + p.curTok().start
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    p.advance()
    mut val ty: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Colon => {
            p.advance()
            ty = parseType(p: inout p)
        }
        _ => {}
    }
    return <FieldAst name=name ty=ty isMut=false vis=0 hasDefault=false defaultVal=emptyExpr() span=<Span start=fStart end=p.prevEnd() /> />
}

// An enum declaration. The cursor is at `enum`.
export fn parseEnumDecl(p: inout P) -> DeclAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    val typeParams: Array[String] = parseTypeParamNames(p: inout p)
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val variants: Array[VariantAst] = []
    mut val defaultExts: Array[String] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.Ident => {
                // `defaultExtension #A #B` in the enum body (spec/09): name the
                // extensions whose methods join this enum's bare surface (same as for
                // a struct). Handled before the variant-name path (it is an Ident too).
                if curIs(p: inout p, kw: "defaultExtension") {
                    p.advance()
                    mut val moreExt: Bool = true
                    while moreExt {
                        match p.curKind() {
                            Kind.Hash => {
                                p.advance()
                                defaultExts.append(p.text(t: p.curTok()))
                                p.advance()
                            }
                            _ => { moreExt = false }
                        }
                    }
                } else {
                val vTok: Tok = p.curTok()
                val vName: String = p.text(t: vTok)
                val vStart: U64 = p.base + vTok.start
                p.advance()
                mut val vfields: Array[FieldAst] = []
                match p.curKind() {
                    Kind.LBrace => {
                        // variant payloads are record-form `V(x: I32, ...)` (spec/05):
                        // the brace form is rejected with a hint (acceptance soundness).
                        p.fail(off: p.base + p.curTok().start, msg: "enum variant payloads use parentheses, e.g. `Foo(x: I32, y: I32)`")
                    }
                    Kind.LParen => {
                        p.advance()
                        while true {
                            p.skipNewlines()
                            match p.curKind() {
                                Kind.RParen => {
                                    p.advance()
                                    break
                                }
                                Kind.Eof => { break }
                                Kind.Ident => {
                                    vfields.append(parseVariantField(p: inout p))
                                    match p.curKind() {
                                        Kind.Comma => { p.advance() }
                                        _ => {}
                                    }
                                }
                                _ => { p.advance() }
                            }
                        }
                    }
                    _ => {}
                }
                variants.append(<VariantAst name=vName fields=vfields span=<Span start=vStart end=p.prevEnd() /> />)
                }
            }
            _ => { p.advance() }
        }
    }
    return <DeclAst kind=<DeclKind.Enum /> name=name nameSpan=nameSpan typeParams=typeParams span=<Span start=sStart end=p.prevEnd() /> isUnique=false fields=[] hasDeinit=false deinitBody=emptyBlock() variants=variants params=[] hasRet=false ret=emptyTypeAst() isAsync=false whereParams=[] whereTraits=[] body=emptyBlock() defaultExts=defaultExts />
}

// A function parameter `name[~]: [inout|move|borrow] Type [= expr]`. The cursor is
// at the parameter name.
fn parseParamAst(p: inout P) -> ParamAst {
    val pStart: U64 = p.base + p.curTok().start
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    p.advance()
    mut val noLabel: Bool = false
    match p.curKind() {
        Kind.Tilde => {
            if p.peekKind(off: 1) == <Kind.Colon /> {
                p.advance()
                noLabel = true
            }
        }
        _ => {}
    }
    mut val ty: TypeAst = emptyTypeAst()
    mut val isInout: Bool = false
    mut val isMove: Bool = false
    mut val isBorrow: Bool = false
    match p.curKind() {
        Kind.Colon => {
            p.advance()
            match p.curKind() {
                Kind.KwInout => {
                    p.advance()
                    isInout = true
                }
                Kind.KwMove => {
                    p.advance()
                    isMove = true
                }
                Kind.KwBorrow => {
                    p.advance()
                    isBorrow = true
                }
                _ => {}
            }
            ty = parseType(p: inout p)
        }
        _ => {}
    }
    mut val hasDefault: Bool = false
    mut val defaultVal: ExprAst = emptyExpr()
    match p.curKind() {
        Kind.Eq => {
            p.advance()
            defaultVal = parseExprAst(p: inout p)
            hasDefault = true
        }
        _ => {}
    }
    return <ParamAst name=name ty=ty isInout=isInout isMove=isMove isBorrow=isBorrow noLabel=noLabel hasDefault=hasDefault defaultVal=defaultVal span=<Span start=pStart end=p.prevEnd() /> />
}

// A parenthesized parameter list `( params )`. The cursor is at `(` (or anything
// else for a zero-arg fn with no list).
fn parseParamAsts(p: inout P) -> Array[ParamAst] {
    mut val params: Array[ParamAst] = []
    match p.curKind() {
        Kind.LParen => {
            p.advance()
            while true {
                p.skipNewlines()
                match p.curKind() {
                    Kind.RParen => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    _ => {
                        params.append(parseParamAst(p: inout p))
                    }
                }
            }
        }
        _ => {}
    }
    return params
}

// A `where T: A + B, U: C` trait-bound clause (spec/08) into parallel name lists
// (one (param, trait) pair per `+`/`,` atom). Appends into `params`/`traits`. The
// cursor may or may not be at `where`; a non-`where` token leaves both untouched.
// Mirrors the compiler's parseWhereClause.
fn parseWhereNames(p: inout P, params: inout Array[String], traits: inout Array[String]) {
    if curIs(p: inout p, kw: "where") {
        p.advance()
        mut val cont: Bool = true
        while cont {
            p.skipNewlines()
            match p.curKind() {
                Kind.Ident => {
                    val pName: String = p.text(t: p.curTok())
                    p.advance()
                    match p.curKind() {
                        Kind.Colon => { p.advance() }
                        _ => {}
                    }
                    mut val moreTraits: Bool = true
                    while moreTraits {
                        match p.curKind() {
                            Kind.Ident => {
                                val tName: String = p.text(t: p.curTok())
                                p.advance()
                                // optional trait type arguments `[I64]` / `[Item = Foo]`
                                // (spec/08): the bound pipeline records a trait by name
                                // only (conformance matches by name + arity), so the args
                                // are consumed and currently discarded — they do not yet
                                // disambiguate multiple conformances. Skip a balanced `[...]`.
                                match p.curKind() {
                                    Kind.LBracket => {
                                        mut val depth: U64 = 0
                                        mut val skipping: Bool = true
                                        while skipping {
                                            match p.curKind() {
                                                Kind.LBracket => {
                                                    depth += 1U64
                                                    p.advance()
                                                }
                                                Kind.RBracket => {
                                                    depth -= 1U64
                                                    p.advance()
                                                    if depth == 0U64 {
                                                        skipping = false
                                                    }
                                                }
                                                Kind.Eof => { skipping = false }
                                                _ => { p.advance() }
                                            }
                                        }
                                    }
                                    _ => {}
                                }
                                params.append(pName)
                                traits.append(tName)
                            }
                            _ => {}
                        }
                        match p.curKind() {
                            Kind.Plus => { p.advance() }
                            _ => { moreTraits = false }
                        }
                    }
                    match p.curKind() {
                        Kind.Comma => { p.advance() }
                        _ => { cont = false }
                    }
                }
                _ => { cont = false }
            }
        }
    }
}

// A function declaration `fn name[T,...](params) [-> Ret] [where ...] { body }`.
// The cursor is at `fn` (a leading `async`, if any, is already consumed and passed
// as `isAsync`). The body is parsed; the where-bounds are captured.
export fn parseFuncDecl(p: inout P, isAsync: Bool) -> DeclAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    val typeParams: Array[String] = parseTypeParamNames(p: inout p)
    val params: Array[ParamAst] = parseParamAsts(p: inout p)
    mut val hasRet: Bool = false
    mut val ret: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Arrow => {
            p.advance()
            ret = parseType(p: inout p)
            hasRet = true
        }
        _ => {}
    }
    mut val whereParams: Array[String] = []
    mut val whereTraits: Array[String] = []
    parseWhereNames(p: inout p, params: inout whereParams, traits: inout whereTraits)
    p.skipNewlines()
    val body: BlockAst = parseBlockAst(p: inout p)
    return <DeclAst kind=<DeclKind.Func /> name=name nameSpan=nameSpan typeParams=typeParams span=<Span start=sStart end=p.prevEnd() /> isUnique=false fields=[] hasDeinit=false deinitBody=emptyBlock() variants=[] params=params hasRet=hasRet ret=ret isAsync=isAsync whereParams=whereParams whereTraits=whereTraits body=body />
}

// Parse an item's source into a `DeclAst` (struct / enum / fn). `source` is the
// item's own text (the declaration through its closing `}`); `start` is that
// text's absolute offset in the original file, used as the base so every emitted
// `Span` is in ORIGINAL coordinates (an input error points at the user's text);
// `end` (= start + source length) is informational. An item the M1 subset doesn't
// model yet yields an empty struct decl (logged: traits/impls/newtypes additive).
export fn parseItem(source: String, start: U64, end: U64) -> TopItemAst {
    val sb: Array[U8] = source.bytes()
    mut val lx: Lexer = <Lexer bytes=sb pos=0 toks=[] depth=0 />
    lex(lx: inout lx)
    mut val p: P = <P bytes=sb toks=lx.toks pos=0 base=start />
    skipLeading(p: inout p)
    // dispatch the one annotated item, mirroring parseProgramAst (a macro target is
    // a struct / enum / fn / impl / trait / extern). The result is the `TopItemAst`
    // the macro's `derive` matches on.
    match p.curKind() {
        Kind.KwStruct => { return <TopItemAst.Decl d=parseStructDecl(p: inout p, isUnique: false) /> }
        Kind.KwUnique => {
            p.advance()
            return <TopItemAst.Decl d=parseStructDecl(p: inout p, isUnique: true) />
        }
        Kind.KwEnum => { return <TopItemAst.Decl d=parseEnumDecl(p: inout p) /> }
        Kind.KwFn => { return <TopItemAst.Decl d=parseFuncDecl(p: inout p, isAsync: false) /> }
        Kind.KwAsync => {
            p.advance()
            return <TopItemAst.Decl d=parseFuncDecl(p: inout p, isAsync: true) />
        }
        Kind.KwExtern => { return <TopItemAst.Extern e=parseExternDecl(p: inout p) /> }
        Kind.Ident => {
            if curIs(p: inout p, kw: "trait") {
                return <TopItemAst.Trait t=parseTraitDecl(p: inout p) />
            }
            if curIs(p: inout p, kw: "pub") {
                p.advance()
                if curIs(p: inout p, kw: "impl") {
                    return <TopItemAst.Impl im=parseImplDecl(p: inout p, isPub: true) />
                }
                return emptyTopItem(off: p.base + p.curTok().start)
            }
            if curIs(p: inout p, kw: "impl") {
                return <TopItemAst.Impl im=parseImplDecl(p: inout p, isPub: false) />
            }
            return emptyTopItem(off: p.base + p.curTok().start)
        }
        _ => { return emptyTopItem(off: start) }
    }
}

// A placeholder `TopItemAst` for an item the parser does not recognize (a macro on
// an unsupported target). An empty struct declaration so `.derive` can match `Decl`
// and fall through.
fn emptyTopItem(off: U64) -> TopItemAst {
    return <TopItemAst.Decl d=<DeclAst kind=<DeclKind.Struct /> name="" nameSpan=<Span start=off end=off /> typeParams=[] span=<Span start=off end=off /> isUnique=false fields=[] hasDeinit=false deinitBody=emptyBlock() variants=[] params=[] hasRet=false ret=emptyTypeAst() isAsync=false whereParams=[] whereTraits=[] body=emptyBlock() /> />
}

// Parse a single nominal declaration (`[unique] struct` / `enum` / `fn`) from the
// compiler's own token stream — the cursor is already at the item keyword (the
// frontend's `parseProgram` dispatched). Mirrors `parseItem`'s match without the
// re-lex/skipLeading. The frontend drives this over its `P` (base 0 = absolute
// c.bytes offsets) and lowers the result into its arena (Codegen/Lower.pw).
export fn parseDecl(p: inout P) -> DeclAst {
    match p.curKind() {
        Kind.KwStruct => { return parseStructDecl(p: inout p, isUnique: false) }
        Kind.KwUnique => {
            p.advance()
            return parseStructDecl(p: inout p, isUnique: true)
        }
        Kind.KwEnum => { return parseEnumDecl(p: inout p) }
        Kind.KwFn => { return parseFuncDecl(p: inout p, isAsync: false) }
        Kind.KwAsync => {
            p.advance()
            return parseFuncDecl(p: inout p, isAsync: true)
        }
        _ => {
            val off: U64 = p.base + p.curTok().start
            return <DeclAst kind=<DeclKind.Struct /> name="" nameSpan=<Span start=off end=off /> typeParams=[] span=<Span start=off end=off /> isUnique=false fields=[] hasDeinit=false deinitBody=emptyBlock() variants=[] params=[] hasRet=false ret=emptyTypeAst() isAsync=false whereParams=[] whereTraits=[] body=emptyBlock() />
        }
    }
}

// Parse `assoc val NAME: T = expr` (cursor at `val`) and synthesize a zero-arg
// `assoc fn NAME() -> T { return expr }` MemberAst (spec/05). The constant rides the
// existing assoc-fn path; `Type.NAME` resolves to a call.
fn parseAssocValMember(p: inout P) -> MemberAst {
    val vStart: U64 = p.base + p.curTok().start
    p.advance()
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    mut val ty: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Colon => {
            p.advance()
            ty = parseType(p: inout p)
        }
        _ => {}
    }
    match p.curKind() {
        Kind.Eq => { p.advance() }
        _ => {}
    }
    val init: ExprAst = parseExprAst(p: inout p)
    mut val stmts: Array[StmtAst] = []
    stmts.append(<StmtAst.Return value=init hasValue=true span=<Span start=vStart end=p.prevEnd() /> />)
    val body: BlockAst = <BlockAst stmts=stmts />
    return <MemberAst kind=<MemberKind.AssocFn /> name=name nameSpan=nameSpan typeParams=[] params=[] hasRet=true ret=ty whereParams=[] whereTraits=[] isAsync=false selfInout=false selfMove=false isVia=false viaName="" body=body assocTy=emptyTypeAst() />
}

// Parse a method/assoc-fn member after its mode keyword(s) and `fn` are consumed
// (cursor at the method name): `name[T,...](params) [-> Ret] [where ...]
// (via real | { body })`. `kind`/`selfInout`/`selfMove`/`isAsync` come from the
// mode keyword the caller already consumed.
fn parseMethodAfterFn(p: inout P, kind: MemberKind, selfInout: Bool, selfMove: Bool, isAsync: Bool) -> MemberAst {
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    val typeParams: Array[String] = parseTypeParamNames(p: inout p)
    val params: Array[ParamAst] = parseParamAsts(p: inout p)
    mut val hasRet: Bool = false
    mut val ret: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Arrow => {
            p.advance()
            ret = parseType(p: inout p)
            hasRet = true
        }
        _ => {}
    }
    mut val whereParams: Array[String] = []
    mut val whereTraits: Array[String] = []
    parseWhereNames(p: inout p, params: inout whereParams, traits: inout whereTraits)
    // `via real`: witnesses a requirement by aliasing an existing method (no body).
    mut val isVia: Bool = false
    mut val viaName: String = ""
    if curIs(p: inout p, kw: "via") {
        p.advance()
        viaName = p.text(t: p.curTok())
        p.advance()
        isVia = true
    }
    mut val body: BlockAst = emptyBlock()
    if !(isVia) {
        p.skipNewlines()
        body = parseBlockAst(p: inout p)
    }
    return <MemberAst kind=kind name=name nameSpan=nameSpan typeParams=typeParams params=params hasRet=hasRet ret=ret whereParams=whereParams whereTraits=whereTraits isAsync=isAsync selfInout=selfInout selfMove=selfMove isVia=isVia viaName=viaName body=body assocTy=emptyTypeAst() />
}

// An `[pub] impl[T] Recv [as Trait] [where ...] { members }` block (spec/07,08).
// The cursor is at the `impl` ident (the leading `pub`, if any, is already consumed
// and passed as `isPub`). Mirrors the compiler's parseImpl.
export fn parseImplDecl(p: inout P, isPub: Bool, extName: String = "") -> ImplAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val implParams: Array[String] = parseTypeParamNames(p: inout p)
    val recvType: TypeAst = parseType(p: inout p)
    mut val isTraitImpl: Bool = false
    mut val traitName: String = ""
    mut val traitArgs: Array[TypeAst] = []
    match p.curKind() {
        Kind.KwAs => {
            p.advance()
            traitName = p.text(t: p.curTok())
            p.advance()
            isTraitImpl = true
            // trait type arguments `as Add[V]` (spec/12): bind the trait's type
            // parameters. Comma-separated full types until `]`.
            match p.curKind() {
                Kind.LBracket => {
                    p.advance()
                    while true {
                        match p.curKind() {
                            Kind.RBracket => {
                                p.advance()
                                break
                            }
                            Kind.Eof => { break }
                            Kind.Comma => { p.advance() }
                            _ => { traitArgs.append(parseType(p: inout p)) }
                        }
                    }
                }
                _ => {}
            }
        }
        _ => {}
    }
    mut val whereParams: Array[String] = []
    mut val whereTraits: Array[String] = []
    parseWhereNames(p: inout p, params: inout whereParams, traits: inout whereTraits)
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val members: Array[MemberAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.KwInout => {
                p.advance()
                match p.curKind() {
                    Kind.KwFn => { p.advance() }
                    _ => {}
                }
                members.append(parseMethodAfterFn(p: inout p, kind: <MemberKind.Method />, selfInout: true, selfMove: false, isAsync: false))
            }
            Kind.KwFn => {
                p.advance()
                members.append(parseMethodAfterFn(p: inout p, kind: <MemberKind.Method />, selfInout: false, selfMove: false, isAsync: false))
            }
            Kind.KwAsync => {
                p.advance()
                mut val asyncMove: Bool = false
                match p.curKind() {
                    Kind.KwMove => {
                        p.advance()
                        asyncMove = true
                    }
                    _ => {}
                }
                match p.curKind() {
                    Kind.KwFn => { p.advance() }
                    _ => {}
                }
                members.append(parseMethodAfterFn(p: inout p, kind: <MemberKind.Method />, selfInout: false, selfMove: asyncMove, isAsync: true))
            }
            Kind.KwMove => {
                p.advance()
                match p.curKind() {
                    Kind.KwFn => { p.advance() }
                    _ => {}
                }
                members.append(parseMethodAfterFn(p: inout p, kind: <MemberKind.Method />, selfInout: false, selfMove: true, isAsync: false))
            }
            Kind.KwBorrow => {
                p.advance()
                match p.curKind() {
                    Kind.KwFn => { p.advance() }
                    _ => {}
                }
                members.append(parseMethodAfterFn(p: inout p, kind: <MemberKind.Method />, selfInout: false, selfMove: false, isAsync: false))
            }
            Kind.KwDeinit => {
                val dStart: U64 = p.base + p.curTok().start
                p.advance()
                p.skipNewlines()
                val dbody: BlockAst = parseBlockAst(p: inout p)
                members.append(<MemberAst kind=<MemberKind.Deinit /> name="" nameSpan=<Span start=dStart end=dStart /> typeParams=[] params=[] hasRet=false ret=emptyTypeAst() whereParams=[] whereTraits=[] isAsync=false selfInout=false selfMove=false isVia=false viaName="" body=dbody assocTy=emptyTypeAst() />)
            }
            _ => {
                if curIs(p: inout p, kw: "factory") || curIs(p: inout p, kw: "optional") || curIs(p: inout p, kw: "result") {
                    // `factory` (spec/05): a bare `factory` publishes the default
                    // memberwise factory (the span feeds the publication gate). A
                    // `factory name(params) { … }` is a custom NAMED factory, lowered as
                    // an AssocFn returning Self and invoked via `<Type.name …/>`. A
                    // leading `optional` / `result[E]` makes it fallible (→ Optional[Self]
                    // / Result[Self, E]).
                    mut val facKind: U64 = 0
                    mut val facErr: TypeAst = emptyTypeAst()
                    if curIs(p: inout p, kw: "optional") {
                        p.advance()
                        facKind = 1U64
                    } else {
                        if curIs(p: inout p, kw: "result") {
                            p.advance()
                            match p.curKind() {
                                Kind.LBracket => {
                                    p.advance()
                                    facErr = parseType(p: inout p)
                                    match p.curKind() {
                                        Kind.RBracket => { p.advance() }
                                        _ => {}
                                    }
                                }
                                _ => {}
                            }
                            facKind = 2U64
                        }
                    }
                    val fTok: Tok = p.curTok()
                    val fSpan: Span = p.spanOf(t: fTok)
                    p.advance()
                    match p.curKind() {
                        Kind.Ident => {
                            val nameTok: Tok = p.curTok()
                            val fname: String = p.text(t: nameTok)
                            val fnameSpan: Span = p.spanOf(t: nameTok)
                            p.advance()
                            val fparams: Array[ParamAst] = parseParamAsts(p: inout p)
                            val fbody: BlockAst = parseBlockAst(p: inout p)
                            members.append(<MemberAst kind=<MemberKind.AssocFn /> name=fname nameSpan=fnameSpan typeParams=[] params=fparams hasRet=false ret=emptyTypeAst() whereParams=[] whereTraits=[] isAsync=false selfInout=false selfMove=false isVia=false viaName="" body=fbody assocTy=emptyTypeAst() isFactory=true factoryKind=facKind factoryErr=facErr />)
                        }
                        Kind.LParen => {
                            // anonymous factory `factory(label: T) { … }` (spec/05) — the
                            // `From` shape `factory(from: x)` → invoked via `<T from=x/>` /
                            // `x as T`. Named by its (single) parameter label so the
                            // construction can route by field label.
                            val fparams: Array[ParamAst] = parseParamAsts(p: inout p)
                            val fbody: BlockAst = parseBlockAst(p: inout p)
                            mut val anonName: String = ""
                            if fparams.count > 0 {
                                anonName = fparams[0].name
                            }
                            members.append(<MemberAst kind=<MemberKind.AssocFn /> name=anonName nameSpan=fSpan typeParams=[] params=fparams hasRet=false ret=emptyTypeAst() whereParams=[] whereTraits=[] isAsync=false selfInout=false selfMove=false isVia=false viaName="" body=fbody assocTy=emptyTypeAst() isFactory=true factoryKind=facKind factoryErr=facErr />)
                        }
                        _ => {
                            members.append(<MemberAst kind=<MemberKind.Factory /> name="factory" nameSpan=fSpan typeParams=[] params=[] hasRet=false ret=emptyTypeAst() whereParams=[] whereTraits=[] isAsync=false selfInout=false selfMove=false isVia=false viaName="" body=emptyBlock() assocTy=emptyTypeAst() />)
                        }
                    }
                } else {
                if curIs(p: inout p, kw: "assoc") {
                    p.advance()
                    match p.curKind() {
                        Kind.KwVal => {
                            // `assoc val NAME: T = expr` (spec/05): a per-type constant.
                            // Desugar to a zero-arg `assoc fn NAME() -> T { return expr }`
                            // so it rides the existing assoc-fn machinery (`Type.NAME`).
                            members.append(parseAssocValMember(p: inout p))
                        }
                        _ => {
                            match p.curKind() {
                                Kind.KwFn => { p.advance() }
                                _ => {}
                            }
                            members.append(parseMethodAfterFn(p: inout p, kind: <MemberKind.AssocFn />, selfInout: false, selfMove: false, isAsync: false))
                        }
                    }
                } else {
                    if curIs(p: inout p, kw: "type") {
                        p.advance()
                        val atTok: Tok = p.curTok()
                        val atName: String = p.text(t: atTok)
                        val atSpan: Span = p.spanOf(t: atTok)
                        p.advance()
                        match p.curKind() {
                            Kind.Eq => { p.advance() }
                            _ => {}
                        }
                        val aty: TypeAst = parseType(p: inout p)
                        members.append(<MemberAst kind=<MemberKind.AssocType /> name=atName nameSpan=atSpan typeParams=[] params=[] hasRet=false ret=emptyTypeAst() whereParams=[] whereTraits=[] isAsync=false selfInout=false selfMove=false isVia=false viaName="" body=emptyBlock() assocTy=aty />)
                    } else {
                        p.advance()
                    }
                }
                }
            }
        }
    }
    return <ImplAst recvType=recvType implParams=implParams isTraitImpl=isTraitImpl traitName=traitName traitArgs=traitArgs whereParams=whereParams whereTraits=whereTraits isPub=isPub members=members span=<Span start=sStart end=p.prevEnd() /> extName=extName />
}

// A body-less function signature `name[T,...](params) [-> ret]` (a trait requirement
// or extern declaration). The leading `fn`/`assoc fn`/`inout fn` is already consumed
// (the cursor is at the name); `isAssoc` records the form. Mirrors parseReqSig.
fn parseSigAst(p: inout P, isAssoc: Bool, selfInout: Bool = false) -> SigAst {
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    val typeParams: Array[String] = parseTypeParamNames(p: inout p)
    val params: Array[ParamAst] = parseParamAsts(p: inout p)
    mut val hasRet: Bool = false
    mut val ret: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Arrow => {
            p.advance()
            ret = parseType(p: inout p)
            hasRet = true
        }
        _ => {}
    }
    return <SigAst name=name nameSpan=nameSpan typeParams=typeParams params=params hasRet=hasRet ret=ret isAssoc=isAssoc selfInout=selfInout />
}

// A `trait Name [: Super + ...] { fn req ... ; type Item }` declaration (spec/08).
// The cursor is at the `trait` ident. Mirrors the compiler's parseTrait.
export fn parseTraitDecl(p: inout P) -> TraitAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val nameTok: Tok = p.curTok()
    val name: String = p.text(t: nameTok)
    val nameSpan: Span = p.spanOf(t: nameTok)
    p.advance()
    // trait type parameters `trait Add[Rhs]` (spec/12), before `: Super` / `{`.
    val typeParams: Array[String] = parseTypeParamNames(p: inout p)
    mut val supertraits: Array[String] = []
    match p.curKind() {
        Kind.Colon => {
            p.advance()
            mut val more: Bool = true
            while more {
                match p.curKind() {
                    Kind.Ident => {
                        supertraits.append(p.text(t: p.curTok()))
                        p.advance()
                    }
                    _ => {}
                }
                match p.curKind() {
                    Kind.Plus => { p.advance() }
                    _ => { more = false }
                }
            }
        }
        _ => {}
    }
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val reqs: Array[SigAst] = []
    mut val assocTypes: Array[String] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.KwFn => {
                p.advance()
                reqs.append(parseSigAst(p: inout p, isAssoc: false))
            }
            Kind.KwInout => {
                // `inout fn next()` requirement: conformance matches by selector, not
                // self-mode, so the `inout` is consumed and a plain req recorded.
                p.advance()
                match p.curKind() {
                    Kind.KwFn => { p.advance() }
                    _ => {}
                }
                reqs.append(parseSigAst(p: inout p, isAssoc: false, selfInout: true))
            }
            _ => {
                if curIs(p: inout p, kw: "factory") || curIs(p: inout p, kw: "optional") || curIs(p: inout p, kw: "result") {
                    // a factory requirement `[optional | result[E]] factory name(params)`
                    // (spec/05,12 — e.g. `TryFrom`'s `result[Error] factory checked(source:)`,
                    // `Chain`'s `factory fromValue/empty`). Recorded as an assoc-fn
                    // requirement by its SELECTOR (name + labels); the fallible wrapper
                    // (optional/result[E]) and the implicit `Self` return are the impl's
                    // concern. Witnessing matches by selector and the requirement return is
                    // left implicit (reqReturnMismatch is lenient for the Result/Optional/
                    // Self shape), so a conforming `impl I8 as TryFrom[I64]` factory satisfies
                    // it and the built-in-impl gate exempts the witnessing factory.
                    if curIs(p: inout p, kw: "optional") {
                        p.advance()
                    } else {
                        if curIs(p: inout p, kw: "result") {
                            p.advance()
                            match p.curKind() {
                                Kind.LBracket => {
                                    p.advance()
                                    val ignErr: TypeAst = parseType(p: inout p)
                                    match p.curKind() {
                                        Kind.RBracket => { p.advance() }
                                        _ => {}
                                    }
                                }
                                _ => {}
                            }
                        }
                    }
                    if curIs(p: inout p, kw: "factory") {
                        p.advance()
                    }
                    reqs.append(parseSigAst(p: inout p, isAssoc: true))
                } else {
                if curIs(p: inout p, kw: "assoc") {
                    p.advance()
                    match p.curKind() {
                        Kind.KwFn => { p.advance() }
                        _ => {}
                    }
                    reqs.append(parseSigAst(p: inout p, isAssoc: true))
                } else {
                    if curIs(p: inout p, kw: "type") {
                        p.advance()
                        match p.curKind() {
                            Kind.Ident => {
                                assocTypes.append(p.text(t: p.curTok()))
                                p.advance()
                            }
                            _ => {}
                        }
                    } else {
                        p.advance()
                    }
                }
                }
            }
        }
    }
    return <TraitAst name=name nameSpan=nameSpan typeParams=typeParams supertraits=supertraits reqs=reqs assocTypes=assocTypes span=<Span start=sStart end=p.prevEnd() /> />
}

// An `extern "plew-intrinsic" { fn ... ; struct ... }` block (spec/15). The cursor
// is at the `extern` keyword. Mirrors the compiler's parseExtern.
export fn parseExternDecl(p: inout P) -> ExternAst {
    val externTok: Tok = p.curTok()
    val abiSpan: Span = p.spanOf(t: externTok)
    p.advance()
    mut val abiOk: Bool = false
    mut val abiC: Bool = false
    match p.curKind() {
        Kind.Str => {
            val t: Tok = p.curTok()
            if t.len >= 2 {
                if rangeEquals(bytes: p.bytes, start: t.start + 1, len: t.len - 2, kw: "plew-intrinsic") {
                    abiOk = true
                }
            }
            p.advance()
        }
        Kind.LParen => {
            // bareword ABI selector `extern(c)` / `extern(plewIntrinsic)` (spec/15):
            // ABI is a compiler-closed set, written without quotes (like import paths).
            p.advance()
            val t: Tok = p.curTok()
            if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "c") {
                abiOk = true
                abiC = true
            } else {
                if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "plewIntrinsic") {
                    abiOk = true
                }
            }
            p.advance()
            match p.curKind() {
                Kind.RParen => { p.advance() }
                _ => {}
            }
        }
        _ => {}
    }
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val fns: Array[SigAst] = []
    mut val structNames: Array[String] = []
    mut val structTypeParams: Array[Array[String]] = []
    mut val structSpans: Array[Span] = []
    mut val structDirectives: Array[DirectiveAst] = []
    // a `@[...]` directive seen since the last item — attached to the next struct/type
    // (spec/16: a derive on an opaque extern lang-item, e.g. `@[IntTryFrom] struct I8`).
    mut val pendingDir: DirectiveAst = <DirectiveAst reqs=[] />
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.KwFn => {
                p.advance()
                fns.append(parseSigAst(p: inout p, isAssoc: false))
                pendingDir = <DirectiveAst reqs=[] />
            }
            Kind.KwStruct => {
                val kwSpan: Span = p.spanOf(t: p.curTok())
                p.advance()
                val sTok: Tok = p.curTok()
                structNames.append(p.text(t: sTok))
                structSpans.append(<Span start=kwSpan.start end=p.spanOf(t: sTok).end />)
                structDirectives.append(pendingDir)
                pendingDir = <DirectiveAst reqs=[] />
                p.advance()
                // optional generic params `[T, …]` (`extern { struct Buffer[T] }`): a
                // generic opaque intrinsic. Non-generic structs get an empty list.
                structTypeParams.append(parseTypeParamNames(p: inout p))
            }
            _ => {
                // `type Name` — opaque foreign type (spec/15 FFI: `extern(c) { type
                // LLVMModuleRef }`). Captured like `struct Name` (a body-less opaque
                // type). `type` is a contextual keyword (an Ident), not a token kind.
                if curIs(p: inout p, kw: "type") {
                    val kwSpan: Span = p.spanOf(t: p.curTok())
                    p.advance()
                    val tTok: Tok = p.curTok()
                    structNames.append(p.text(t: tTok))
                    structTypeParams.append([])
                    structSpans.append(<Span start=kwSpan.start end=p.spanOf(t: tTok).end />)
                    structDirectives.append(pendingDir)
                    pendingDir = <DirectiveAst reqs=[] />
                    p.advance()
                } else {
                    // a `@[...]` directive (the `@` token followed by `[`) annotating the
                    // next struct/type — parse and stash it; otherwise skip one token.
                    if p.peekKind(off: 1) == <Kind.LBracket /> {
                        pendingDir = parseDirectiveAst(p: inout p)
                    } else {
                        p.advance()
                    }
                }
            }
        }
    }
    return <ExternAst abiOk=abiOk abiC=abiC abiSpan=abiSpan fns=fns structNames=structNames structTypeParams=structTypeParams structSpans=structSpans structDirectives=structDirectives span=<Span start=p.base + externTok.start end=p.prevEnd() /> />
}

// `import <path> [with { name [as Q], ... }]` or `part <path>` (spec/15). The cursor
// is at the `import`/`part` ident (`isImport` distinguishes: an import starts a fresh
// module, a part joins the current one). Captures the full contiguous path span (for
// the loader to resolve to a file — parse-driven loading), the last segment, and each
// `with` name (original span — feeds moduleOf for the importing module). A `part` has
// no `with` list. Mirrors the compiler's parseImport + collectParts.
fn parseImportAst(p: inout P, isImport: Bool) -> ImportAst {
    val startOff: U64 = p.base + p.curTok().start
    p.advance()
    return parseImportTail(p: inout p, isImport: isImport, reExport: false, startOff: startOff)
}

// The path + `with { names }` body of an `import`/`part`/re-export, with the cursor
// already past the leading keyword (`import`/`part`/`export`). `startOff` is the
// keyword's offset (for the item span). Shared so a re-export (`export <path> with
// { … }`) parses its path/names with the exact same machinery as `import`.
fn parseImportTail(p: inout P, isImport: Bool, reExport: Bool, startOff: U64) -> ImportAst {
    // the path = contiguous tokens (`@`/`.`/`..`/`/` markers + segments), stopping
    // before a space-separated `with`, a `{`, or a newline.
    mut val pathStart: U64 = p.base + p.curTok().start
    mut val pathEndSlice: U64 = p.curTok().start
    mut val segStartAbs: U64 = pathStart
    mut val segLen: U64 = 0
    mut val firstPath: Bool = true
    mut val sawWith: Bool = false
    while true {
        match p.curKind() {
            Kind.Newline => { break }
            Kind.Eof => { break }
            Kind.LBrace => { break }
            _ => {
                if curIs(p: inout p, kw: "with") {
                    p.advance()
                    sawWith = true
                    break
                }
                val t: Tok = p.curTok()
                if !(firstPath) {
                    if t.start != pathEndSlice {
                        break
                    }
                }
                firstPath = false
                pathEndSlice = t.start + t.len
                match t.kind {
                    Kind.Ident => {
                        segStartAbs = p.base + t.start
                        segLen = t.len
                    }
                    _ => {}
                }
                p.advance()
            }
        }
    }
    val pathEndAbs: U64 = p.base + pathEndSlice
    // a path-level alias `import <path> as F` (spec/15): rename the namespace to F.
    mut val aliasSpan: Span = <Span start=0 end=0 />
    match p.curKind() {
        Kind.KwAs => {
            p.advance()
            match p.curKind() {
                Kind.Ident => {
                    aliasSpan = p.spanOf(t: p.curTok())
                    p.advance()
                }
                _ => {}
            }
            // `as F with { … }` is allowed; fall through to the `with` scan below.
            match p.curKind() {
                Kind.Ident => {
                    if curIs(p: inout p, kw: "with") {
                        p.advance()
                        sawWith = true
                    }
                }
                _ => {}
            }
        }
        _ => {}
    }
    mut val names: Array[String] = []
    mut val nameSpans: Array[Span] = []
    mut val nameAliasSpans: Array[Span] = []
    // `with` must be followed by a `{ … }` selection. Wildcard `import … with *` is
    // intentionally not supported (spec/15): it hides provenance — use a namespace
    // import `import <path>` (then `Ns.name`) for broad access, or `with { … }`.
    if sawWith {
        if !reExport {
            match p.curKind() {
                Kind.LBrace => {}
                Kind.Star => { p.fail(off: p.base + p.curTok().start, msg: "wildcard import `with *` is not supported (spec/15): use a namespace import `import <path>` (then refer to `Ns.name`) for broad access, or `with { … }` to select names") }
                _ => { p.fail(off: p.base + p.curTok().start, msg: "expected `{ … }` after `with` in an import") }
            }
        }
    }
    match p.curKind() {
        Kind.LBrace => {
            p.advance()
            while true {
                p.skipNewlines()
                match p.curKind() {
                    Kind.RBrace => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    Kind.Ident => {
                        val t: Tok = p.curTok()
                        names.append(p.text(t: t))
                        nameSpans.append(p.spanOf(t: t))
                        p.advance()
                        // `name as Q`: bind the local alias `Q` to the imported `name`.
                        mut val alias: Span = <Span start=0 end=0 />
                        match p.curKind() {
                            Kind.KwAs => {
                                p.advance()
                                match p.curKind() {
                                    Kind.Ident => {
                                        alias = p.spanOf(t: p.curTok())
                                        p.advance()
                                    }
                                    _ => {}
                                }
                            }
                            _ => {}
                        }
                        nameAliasSpans.append(alias)
                    }
                    _ => { p.advance() }
                }
            }
        }
        _ => {}
    }
    return <ImportAst pathSpan=<Span start=pathStart end=pathEndAbs /> segSpan=<Span start=segStartAbs end=segStartAbs + segLen /> isImport=isImport names=names nameSpans=nameSpans aliasSpan=aliasSpan nameAliasSpans=nameAliasSpans span=<Span start=startOff end=p.prevEnd() /> />
}

// Optional directive arguments `(label: expr, ...)` after a derive name (spec/16).
// Mirrors the compiler's parseDirectiveArgs.
fn parseDirectiveArgsAst(p: inout P) -> Array[MakeFieldAst] {
    mut val fields: Array[MakeFieldAst] = []
    match p.curKind() {
        Kind.LParen => { p.advance() }
        _ => { return fields }
    }
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RParen => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.Comma => { p.advance() }
            Kind.Ident => {
                val labelTok: Tok = p.curTok()
                val label: String = p.text(t: labelTok)
                val labelSpan: Span = p.spanOf(t: labelTok)
                p.advance()
                match p.curKind() {
                    Kind.Colon => { p.advance() }
                    _ => {}
                }
                val v: ExprAst = parseExprAst(p: inout p)
                fields.append(<MakeFieldAst name=label value=v span=labelSpan />)
            }
            _ => { p.advance() }
        }
    }
    return fields
}

// `@[Name, Name(a: 32), ...]` directive (spec/16). The cursor is at the `@` (lexed
// as Unknown). Mirrors the compiler's parseDirective.
fn parseDirectiveAst(p: inout P) -> DirectiveAst {
    p.advance()
    match p.curKind() {
        Kind.LBracket => { p.advance() }
        _ => {}
    }
    mut val reqs: Array[DeriveReqAst] = []
    while true {
        match p.curKind() {
            Kind.RBracket => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.Comma => { p.advance() }
            Kind.Ident => {
                val t: Tok = p.curTok()
                val name: String = p.text(t: t)
                val nameSpan: Span = p.spanOf(t: t)
                p.advance()
                val args: Array[MakeFieldAst] = parseDirectiveArgsAst(p: inout p)
                reqs.append(<DeriveReqAst name=name nameSpan=nameSpan args=args />)
            }
            _ => { p.advance() }
        }
    }
    return <DirectiveAst reqs=reqs />
}

// `export <decl> | export extern { } | export <path> [with]` (spec/15). The cursor
// is at the `export` ident. Returns the wrapped item (`Export`) or a re-export path
// (`ReExport`, recorded as nothing for now). Mirrors the compiler's parseExport.
fn parseExportAst(p: inout P) -> TopItemAst {
    val startOff: U64 = p.base + p.curTok().start
    p.advance()
    // A declaration keyword (or contextual `trait`/`newtype`) → `export <decl>`. Anything
    // else is a re-export path (`export ./X` / `export @Std/X` / `export /X` [with { … }]),
    // parsed with the shared import-tail machinery (spec/15). The `@…` form is supported:
    // the `@` lexes as Unknown and is consumed as a contiguous path token like any other.
    match p.curKind() {
        Kind.KwExtern => { return <TopItemAst.Export inner=<TopItemAst.Extern e=parseExternDecl(p: inout p) /> /> }
        Kind.KwFn => { return <TopItemAst.Export inner=<TopItemAst.Decl d=parseDecl(p: inout p) /> /> }
        Kind.KwAsync => { return <TopItemAst.Export inner=<TopItemAst.Decl d=parseDecl(p: inout p) /> /> }
        Kind.KwStruct => { return <TopItemAst.Export inner=<TopItemAst.Decl d=parseDecl(p: inout p) /> /> }
        Kind.KwUnique => { return <TopItemAst.Export inner=<TopItemAst.Decl d=parseDecl(p: inout p) /> /> }
        Kind.KwEnum => { return <TopItemAst.Export inner=<TopItemAst.Decl d=parseDecl(p: inout p) /> /> }
        Kind.KwVal => { return <TopItemAst.Export inner=<TopItemAst.GlobalVal s=parseLetAst(p: inout p, mutable: false) /> /> }
        Kind.KwMut => {
            p.advance()
            return <TopItemAst.Export inner=<TopItemAst.GlobalVal s=parseLetAst(p: inout p, mutable: true) /> />
        }
        Kind.Ident => {
            if curIs(p: inout p, kw: "trait") {
                return <TopItemAst.Export inner=<TopItemAst.Trait t=parseTraitDecl(p: inout p) /> />
            }
            // `export newtype Name = Underlying` (spec/10,15): `newtype` is a contextual
            // keyword (an Ident), so it lands here rather than in a `Kind.Kw…` arm.
            if curIs(p: inout p, kw: "newtype") {
                return <TopItemAst.Export inner=parseNewtypeAst(p: inout p, isPub: false) />
            }
            return <TopItemAst.ReExport imp=parseImportTail(p: inout p, isImport: true, reExport: true, startOff: startOff) />
        }
        _ => { return <TopItemAst.ReExport imp=parseImportTail(p: inout p, isImport: true, reExport: true, startOff: startOff) /> }
    }
}

// Parse an `extension Name { impl ... impl ... }` block (spec/09): a named
// bundle of impl blocks. Each impl is emitted as an ordinary TopItemAst.Impl
// tagged with the extension name (so its members reach resolution only through a
// call-site `value#Name.member` view). The extension itself carries no other
// state — it is purely a label on its impls.
fn parseExtensionInto(p: inout P, items: inout Array[TopItemAst]) {
    p.advance()
    val name: String = p.text(t: p.curTok())
    p.advance()
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => { p.fail(off: p.base + p.curTok().start, msg: "expected `{` after `extension Name`") }
    }
    mut val cont: Bool = true
    while cont {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                cont = false
            }
            Kind.Eof => { cont = false }
            _ => {
                if curIs(p: inout p, kw: "impl") {
                    items.append(<TopItemAst.Impl im=parseImplDecl(p: inout p, isPub: false, extName: name) />)
                } else {
                    if curIs(p: inout p, kw: "pub") {
                        p.advance()
                        if curIs(p: inout p, kw: "impl") {
                            items.append(<TopItemAst.Impl im=parseImplDecl(p: inout p, isPub: true, extName: name) />)
                        } else {
                            p.advance()
                        }
                    } else {
                        p.advance()
                    }
                }
            }
        }
    }
}

// Parse a whole program (a file's tokens) into a flat list of top-level items
// (spec/15). The compiler frontend drives this over its own token stream (base=0)
// and lowers each item (Codegen/Lower.pw), following `Import` items to load further
// files. This is the single top-level entry — the compiler has no separate
// declaration/dispatch parser. Mirrors the compiler's old parseProgram dispatch.
export fn parseProgramAst(p: inout P) -> Array[TopItemAst] {
    mut val items: Array[TopItemAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.KwFn => { items.append(<TopItemAst.Decl d=parseDecl(p: inout p) />) }
            Kind.KwAsync => { items.append(<TopItemAst.Decl d=parseDecl(p: inout p) />) }
            Kind.KwStruct => { items.append(<TopItemAst.Decl d=parseDecl(p: inout p) />) }
            Kind.KwUnique => { items.append(<TopItemAst.Decl d=parseDecl(p: inout p) />) }
            Kind.KwEnum => { items.append(<TopItemAst.Decl d=parseDecl(p: inout p) />) }
            Kind.KwExtern => { items.append(<TopItemAst.Extern e=parseExternDecl(p: inout p) />) }
            Kind.KwVal => { items.append(<TopItemAst.GlobalVal s=parseLetAst(p: inout p, mutable: false) />) }
            Kind.KwMut => {
                p.advance()
                items.append(<TopItemAst.GlobalVal s=parseLetAst(p: inout p, mutable: true) />)
            }
            Kind.Ident => {
                if curIs(p: inout p, kw: "import") {
                    items.append(<TopItemAst.Import imp=parseImportAst(p: inout p, isImport: true) />)
                } else {
                    if curIs(p: inout p, kw: "part") {
                        items.append(<TopItemAst.Import imp=parseImportAst(p: inout p, isImport: false) />)
                    } else {
                        if curIs(p: inout p, kw: "export") {
                            items.append(parseExportAst(p: inout p))
                        } else {
                            if curIs(p: inout p, kw: "impl") {
                                items.append(<TopItemAst.Impl im=parseImplDecl(p: inout p, isPub: false) />)
                            } else {
                                if curIs(p: inout p, kw: "pub") {
                                    p.advance()
                                    if curIs(p: inout p, kw: "impl") {
                                        items.append(<TopItemAst.Impl im=parseImplDecl(p: inout p, isPub: true) />)
                                    } else {
                                        p.advance()
                                    }
                                } else {
                                    if curIs(p: inout p, kw: "trait") {
                                        items.append(<TopItemAst.Trait t=parseTraitDecl(p: inout p) />)
                                    } else {
                                        if curIs(p: inout p, kw: "extension") {
                                            parseExtensionInto(p: inout p, items: inout items)
                                        } else {
                                            if curIs(p: inout p, kw: "newtype") {
                                                items.append(parseNewtypeAst(p: inout p, isPub: false))
                                            } else {
                                                p.advance()
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            Kind.Eof => { break }
            _ => {
                if p.peekKind(off: 1) == <Kind.LBracket /> {
                    items.append(<TopItemAst.Directive dir=parseDirectiveAst(p: inout p) />)
                } else {
                    p.advance()
                }
            }
        }
    }
    return items
}


fn binPrecAst(k: Kind) -> I64 {
    return match k {
        Kind.PipePipe => 1
        Kind.AmpAmp => 2
        Kind.EqEq => 3
        Kind.Ne => 3
        Kind.Lt => 3
        Kind.Le => 3
        Kind.Gt => 3
        Kind.Ge => 3
        Kind.Pipe => 5
        Kind.Caret => 6
        Kind.Amp => 7
        Kind.Shl => 8
        Kind.Shr => 8
        Kind.Plus => 9
        Kind.Minus => 9
        Kind.Star => 10
        Kind.Slash => 10
        Kind.Percent => 10
        _ => 0
    }
}

fn isAssignOpAst(k: Kind) -> Bool {
    return match k {
        Kind.Eq => true
        Kind.PlusEq => true
        Kind.MinusEq => true
        Kind.StarEq => true
        Kind.SlashEq => true
        Kind.PercentEq => true
        Kind.AmpEq => true
        Kind.PipeEq => true
        Kind.CaretEq => true
        Kind.ShlEq => true
        Kind.ShrEq => true
        _ => false
    }
}

fn isFloatTypeAst(p: inout P, t: Tok) -> Bool {
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "F32") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "F64") { return true }
    return false
}

fn isIntTypeAst(p: inout P, t: Tok) -> Bool {
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "I8") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "I16") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "I32") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "I64") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "U8") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "U16") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "U32") { return true }
    if rangeEquals(bytes: p.bytes, start: t.start, len: t.len, kw: "U64") { return true }
    return false
}

// Decode a decimal integer token to U64.
fn tokenU64Ast(p: inout P, t: Tok) -> U64 {
    mut val v: U64 = 0
    mut val j: U64 = 0
    mut val base: U64 = 10
    // a base prefix `0x` / `0o` / `0b` (spec/02): select the radix and skip it.
    if t.len >= 2U64 {
        if p.bytes[t.start] == '0' {
            val c1: U8 = p.bytes[t.start + 1U64]
            if c1 == 'x' { base = 16  j = 2 }
            if c1 == 'X' { base = 16  j = 2 }
            if c1 == 'o' { base = 8  j = 2 }
            if c1 == 'O' { base = 8  j = 2 }
            if c1 == 'b' { base = 2  j = 2 }
            if c1 == 'B' { base = 2  j = 2 }
        }
    }
    while j < t.len {
        val ch: U8 = p.bytes[t.start + j]
        if ch == '_' {
            // a digit separator (`1_000`, `0xFF_FF`): ignored in the value.
        } else {
            v = v * base + hexDigitValueAst(b: ch)
        }
        j += 1
    }
    return v
}

// `s` with every `_` byte removed (a float literal's digit separators).
fn stripUnderscoresAst(s: String) -> String {
    mut val out: Array[U8] = []
    mut val i: U64 = 0
    while i < s.bytes().count {
        if s.bytes()[i] != '_' {
            out.append(s.bytes()[i])
        }
        i += 1
    }
    return stringFromBytesUnchecked(b: out)
}

// The numeric value of a base-16 digit byte (`0`-`9` / `a`-`f` / `A`-`F`); also
// covers the base-2/8/10 digit subsets. Assumes the lexer validated the digit.
fn hexDigitValueAst(b: U8) -> U64 {
    if b >= 'a' {
        if b <= 'f' {
            return (b as U64) - 97U64 + 10U64
        }
    }
    if b >= 'A' {
        if b <= 'F' {
            return (b as U64) - 65U64 + 10U64
        }
    }
    return (b as U64) - 48U64
}

// Decode a character literal token `'…'` (span includes both quotes) to its
// codepoint. Mirrors the compiler's charValue, including the single-scalar check:
// a multi-scalar (Grapheme) literal is recorded as an error.
fn charValueAst(p: inout P, t: Tok) -> U64 {
    if t.len < 3 {
        p.fail(off: p.base + t.start, msg: "empty character literal")
        return 0
    }
    val contentLen: U64 = t.len - 2
    val start: U64 = t.start + 1
    val b0: U8 = p.bytes[start]
    if b0 == '\\' {
        if contentLen != 2 {
            p.fail(off: p.base + t.start, msg: "character literal must be a single scalar")
        }
        val e: U8 = p.bytes[start + 1]
        if e == 'n' { return 10 }
        if e == 't' { return 9 }
        if e == 'r' { return 13 }
        if e == '0' { return 0 }
        return e as U64
    }
    mut val consumed: U64 = 1
    mut val value: U64 = 0
    if b0 < 128 {
        consumed = 1
        value = b0 as U64
    } else {
        if b0 < 224 {
            consumed = 2
            value = ((b0 & 31) as U64 << 6) | ((p.bytes[start + 1] & 63) as U64)
        } else {
            if b0 < 240 {
                consumed = 3
                value = ((b0 & 15) as U64 << 12) | ((p.bytes[start + 1] & 63) as U64 << 6) | ((p.bytes[start + 2] & 63) as U64)
            } else {
                consumed = 4
                value = ((b0 & 7) as U64 << 18) | ((p.bytes[start + 1] & 63) as U64 << 12) | ((p.bytes[start + 2] & 63) as U64 << 6) | ((p.bytes[start + 3] & 63) as U64)
            }
        }
    }
    if contentLen != consumed {
        p.fail(off: p.base + t.start, msg: "multi-scalar character literal (Grapheme) is not yet supported")
    }
    return value
}

// Parse a call/construction argument list (current token just past `(`).
fn parseCallArgsAst(p: inout P) -> Array[ArgAst] {
    mut val args: Array[ArgAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RParen => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            _ => {
                val aStart: U64 = p.base + p.curTok().start
                mut val label: String = ""
                mut val hasLabel: Bool = false
                match p.curKind() {
                    Kind.Ident => {
                        if p.peekKind(off: 1) == <Kind.Colon /> {
                            label = p.text(t: p.curTok())
                            hasLabel = true
                            p.advance()
                            p.advance()
                        }
                    }
                    _ => {}
                }
                mut val isInout: Bool = false
                match p.curKind() {
                    Kind.KwInout => {
                        p.advance()
                        isInout = true
                    }
                    _ => {}
                }
                val e: ExprAst = parseExprAst(p: inout p)
                args.append(<ArgAst label=label hasLabel=hasLabel isInout=isInout value=e span=<Span start=aStart end=p.prevEnd() /> />)
                match p.curKind() {
                    Kind.Comma => { p.advance() }
                    _ => {}
                }
            }
        }
    }
    return args
}

// JSX construction `<Type[args].Variant field=expr ... />`. Current token is `<`.
fn parseMakeAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val typeName: String = p.text(t: p.curTok())
    p.advance()
    mut val typeArgs: Array[TypeAst] = []
    match p.curKind() {
        Kind.LBracket => {
            p.advance()
            while true {
                match p.curKind() {
                    Kind.RBracket => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.Comma => { p.advance() }
                    _ => {
                        typeArgs.append(parseType(p: inout p))
                    }
                }
            }
        }
        _ => {}
    }
    mut val variant: String = ""
    mut val isEnum: Bool = false
    match p.curKind() {
        Kind.Dot => {
            p.advance()
            variant = p.text(t: p.curTok())
            p.advance()
            isEnum = true
        }
        _ => {}
    }
    mut val fields: Array[MakeFieldAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.SlashGt => {
                p.advance()
                break
            }
            Kind.Gt => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            Kind.Ident => {
                val fStart: U64 = p.base + p.curTok().start
                val fname: String = p.text(t: p.curTok())
                p.advance()
                match p.curKind() {
                    Kind.Eq => { p.advance() }
                    _ => {}
                }
                val v: ExprAst = parseExprAst(p: inout p)
                fields.append(<MakeFieldAst name=fname value=v span=<Span start=fStart end=p.prevEnd() /> />)
            }
            _ => { p.advance() }
        }
    }
    return <ExprAst.Make typeName=typeName typeArgs=typeArgs variant=variant isEnum=isEnum fields=fields span=<Span start=sStart end=p.prevEnd() /> />
}

fn parsePrimaryAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    match p.curKind() {
        Kind.Int => {
            val t: Tok = p.curTok()
            p.advance()
            val v: U64 = tokenU64Ast(p: inout p, t: t)
            mut val suffix: String = ""
            match p.curKind() {
                Kind.Ident => {
                    val st: Tok = p.curTok()
                    if st.start == t.start + t.len {
                        if isIntTypeAst(p: inout p, t: st) {
                            suffix = p.text(t: st)
                            p.advance()
                        }
                    }
                }
                _ => {}
            }
            return <ExprAst.IntLit value=v isBool=false tySuffix=suffix span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Float => {
            val t: Tok = p.curTok()
            // strip `_` digit separators (`1_000.5`) before the text reaches the float
            // parser (LLVMConstRealOfStringAndSize), which does not accept them.
            val txt: String = stripUnderscoresAst(s: p.text(t: t))
            p.advance()
            mut val suffix: String = ""
            match p.curKind() {
                Kind.Ident => {
                    val st: Tok = p.curTok()
                    if st.start == t.start + t.len {
                        if isFloatTypeAst(p: inout p, t: st) {
                            suffix = p.text(t: st)
                            p.advance()
                        }
                    }
                }
                _ => {}
            }
            return <ExprAst.FloatLit text=txt tySuffix=suffix span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Char => {
            val t: Tok = p.curTok()
            p.advance()
            return <ExprAst.IntLit value=charValueAst(p: inout p, t: t) isBool=false tySuffix="" span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.KwTrue => {
            p.advance()
            return <ExprAst.IntLit value=1 isBool=true tySuffix="" span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.KwFalse => {
            p.advance()
            return <ExprAst.IntLit value=0 isBool=true tySuffix="" span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Str => {
            val t: Tok = p.curTok()
            p.advance()
            return <ExprAst.StrLit raw=p.text(t: t) span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Ident => {
            val t: Tok = p.curTok()
            match p.peekKind(off: 1) {
                Kind.LParen => {
                    p.advance()
                    p.advance()
                    val args: Array[ArgAst] = parseCallArgsAst(p: inout p)
                    return <ExprAst.Call name=p.text(t: t) args=args span=<Span start=sStart end=p.prevEnd() /> />
                }
                _ => {
                    p.advance()
                    return <ExprAst.Ident name=p.text(t: t) span=<Span start=sStart end=p.prevEnd() /> />
                }
            }
        }
        Kind.LParen => {
            val recStart: U64 = p.base + p.curTok().start
            p.advance()
            // unit `()` — the empty anonymous record (spec/02).
            match p.curKind() {
                Kind.RParen => {
                    p.advance()
                    mut val noFields: Array[MakeFieldAst] = []
                    return <ExprAst.RecordLit fields=noFields span=<Span start=recStart end=p.prevEnd() /> />
                }
                _ => {}
            }
            // a labelled / punned anonymous record literal `(x: 1, y: 2)` / `(x, y)`:
            // distinguished from a parenthesized expression by a leading `ident :`
            // (labelled) or `ident ,` (punned — `(x)` alone is grouping; `(x,)` /
            // `(x, y)` are records). Punning makes `(x, y)` into `(x: x, y: y)`.
            mut val isRecord: Bool = false
            match p.curKind() {
                Kind.Ident => {
                    if p.peekKind(off: 1) == <Kind.Colon /> {
                        isRecord = true
                    }
                    if p.peekKind(off: 1) == <Kind.Comma /> {
                        isRecord = true
                    }
                }
                _ => {}
            }
            if isRecord {
                mut val fields: Array[MakeFieldAst] = []
                while true {
                    match p.curKind() {
                        Kind.RParen => { p.advance()  break }
                        Kind.Eof => { break }
                        Kind.Comma => { p.advance() }
                        _ => {
                            val labelTok: Tok = p.curTok()
                            val label: String = p.text(t: labelTok)
                            val fStart: U64 = p.base + labelTok.start
                            p.advance()
                            match p.curKind() {
                                Kind.Colon => {
                                    // explicit `label: value`.
                                    p.advance()
                                    val fv: ExprAst = parseExprAst(p: inout p)
                                    fields.append(<MakeFieldAst name=label value=fv span=<Span start=fStart end=p.prevEnd() /> />)
                                }
                                _ => {
                                    // punning `(x, …)`: the identifier is both the field
                                    // name and the value (`x` => `x: x`).
                                    val pv: ExprAst = <ExprAst.Ident name=label span=<Span start=fStart end=p.prevEnd() /> />
                                    fields.append(<MakeFieldAst name=label value=pv span=<Span start=fStart end=p.prevEnd() /> />)
                                }
                            }
                        }
                    }
                }
                return <ExprAst.RecordLit fields=fields span=<Span start=recStart end=p.prevEnd() /> />
            }
            // otherwise a parenthesized (grouping) expression.
            val inner: ExprAst = parseExprAst(p: inout p)
            match p.curKind() {
                Kind.RParen => { p.advance() }
                _ => { p.fail(off: p.base + p.curTok().start, msg: "expected ')' to close a parenthesized expression") }
            }
            return inner
        }
        Kind.KwFn => {
            p.advance()
            val params: Array[ParamAst] = parseParamAsts(p: inout p)
            mut val hasRet: Bool = false
            mut val ret: TypeAst = emptyTypeAst()
            match p.curKind() {
                Kind.Arrow => {
                    p.advance()
                    ret = parseType(p: inout p)
                    hasRet = true
                }
                _ => {}
            }
            p.skipNewlines()
            val body: BlockAst = parseBlockAst(p: inout p)
            return <ExprAst.Closure params=params hasRet=hasRet ret=ret body=body span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Lt => {
            return parseMakeAst(p: inout p)
        }
        Kind.KwMatch => {
            return parseMatchExprAst(p: inout p)
        }
        Kind.KwIf => {
            return parseIfExprAst(p: inout p)
        }
        Kind.LBracket => {
            p.advance()
            p.skipNewlines()
            // disambiguate dictionary literals from array literals (spec/02): `[:]`
            // is the empty dictionary, `[k: v, ...]` a dictionary, `[]`/`[a, ...]` an
            // array. The fork is decided by a leading `:` (empty) or a `:` right
            // after the first element.
            match p.curKind() {
                Kind.Colon => {
                    p.advance()
                    p.skipNewlines()
                    match p.curKind() {
                        Kind.RBracket => { p.advance() }
                        _ => {}
                    }
                    val noKeys: Array[ExprAst] = []
                    val noVals: Array[ExprAst] = []
                    return <ExprAst.DictLit keys=noKeys vals=noVals span=<Span start=sStart end=p.prevEnd() /> />
                }
                Kind.RBracket => {
                    p.advance()
                    val noElems: Array[ExprAst] = []
                    return <ExprAst.ArrayLit elems=noElems span=<Span start=sStart end=p.prevEnd() /> />
                }
                _ => {}
            }
            // parse the first element directly into `elems` (a temporary argument,
            // not a named local — a named local would be shallow-passed to `append`
            // and then released, dangling the stored copy). A following `:` makes
            // this a dictionary, where `elems` already holds the first key.
            mut val elems: Array[ExprAst] = []
            elems.append(parseExprAst(p: inout p))
            match p.curKind() {
                Kind.Colon => {
                    p.advance()
                    mut val vals: Array[ExprAst] = []
                    vals.append(parseExprAst(p: inout p))
                    match p.curKind() {
                        Kind.Comma => { p.advance() }
                        _ => {}
                    }
                    while true {
                        p.skipNewlines()
                        match p.curKind() {
                            Kind.RBracket => {
                                p.advance()
                                break
                            }
                            Kind.Eof => { break }
                            _ => {
                                elems.append(parseExprAst(p: inout p))
                                match p.curKind() {
                                    Kind.Colon => { p.advance() }
                                    _ => {}
                                }
                                vals.append(parseExprAst(p: inout p))
                                match p.curKind() {
                                    Kind.Comma => { p.advance() }
                                    _ => {}
                                }
                            }
                        }
                    }
                    return <ExprAst.DictLit keys=elems vals=vals span=<Span start=sStart end=p.prevEnd() /> />
                }
                _ => {}
            }
            match p.curKind() {
                Kind.Comma => { p.advance() }
                _ => {}
            }
            while true {
                p.skipNewlines()
                match p.curKind() {
                    Kind.RBracket => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    _ => {
                        elems.append(parseExprAst(p: inout p))
                        match p.curKind() {
                            Kind.Comma => { p.advance() }
                            _ => {}
                        }
                    }
                }
            }
            return <ExprAst.ArrayLit elems=elems span=<Span start=sStart end=p.prevEnd() /> />
        }
        _ => {
            // An unexpected token where an expression (operand) was expected. Without
            // this, a stray token (notably `;`, which Plew does not use as a statement
            // separator — statements end at newlines) was silently turned into a
            // 0-valued Int, surfacing later as a misleading "integer literal has no
            // type from context". Fail loudly at the parser instead.
            val tk: Tok = p.curTok()
            if p.text(t: tk) == ";" {
                p.fail(off: sStart, msg: "`;` is not a statement separator in Plew; put each statement on its own line")
            } else {
                p.fail(off: sStart, msg: "expected an expression")
            }
            p.advance()
            return <ExprAst.IntLit value=0 isBool=false tySuffix="" span=<Span start=sStart end=p.prevEnd() /> />
        }
    }
}

fn parseUnaryAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    if curIs(p: inout p, kw: "try") {
        p.advance()
        val inner: ExprAst = parsePostfixAst(p: inout p)
        return <ExprAst.Try operand=inner span=<Span start=sStart end=p.prevEnd() /> />
    }
    match p.curKind() {
        Kind.KwAwait => {
            p.advance()
            val o: ExprAst = parsePostfixAst(p: inout p)
            return <ExprAst.Await operand=o span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.KwMove => {
            p.advance()
            val o: ExprAst = parsePostfixAst(p: inout p)
            return <ExprAst.Move operand=o isBorrow=false span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.KwBorrow => {
            p.advance()
            val o: ExprAst = parsePostfixAst(p: inout p)
            return <ExprAst.Move operand=o isBorrow=true span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Minus => {
            p.advance()
            val o: ExprAst = parseUnaryAst(p: inout p)
            return <ExprAst.Unary op=57 operand=o span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Bang => {
            p.advance()
            val o: ExprAst = parseUnaryAst(p: inout p)
            return <ExprAst.Unary op=63 operand=o span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.Tilde => {
            p.advance()
            val o: ExprAst = parseUnaryAst(p: inout p)
            return <ExprAst.Unary op=79 operand=o span=<Span start=sStart end=p.prevEnd() /> />
        }
        _ => { return parsePostfixAst(p: inout p) }
    }
}

fn parsePostfixAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    mut val e: ExprAst = parsePrimaryAst(p: inout p)
    while true {
        match p.curKind() {
            Kind.Dot => {
                p.advance()
                val nameTok: Tok = p.curTok()
                val nm: String = p.text(t: nameTok)
                p.advance()
                match p.curKind() {
                    Kind.LParen => {
                        p.advance()
                        val args: Array[ArgAst] = parseCallArgsAst(p: inout p)
                        e = <ExprAst.Method recv=e name=nm nameSpan=p.spanOf(t: nameTok) args=args span=<Span start=sStart end=p.prevEnd() /> />
                    }
                    _ => {
                        e = <ExprAst.Field base=e name=nm span=<Span start=sStart end=p.prevEnd() /> />
                    }
                }
            }
            Kind.OptChain => {
                // `base?.member` (optional chaining, spec/12). Member access only
                // (no method-call chaining yet); short-circuits on a None base.
                p.advance()
                val nameTok: Tok = p.curTok()
                val nm: String = p.text(t: nameTok)
                p.advance()
                e = <ExprAst.OptChain base=e member=nm span=<Span start=sStart end=p.prevEnd() /> />
            }
            Kind.Hash => {
                // `recv#Src...` / `recv#!Src...` (spec/09): an extension (or trait)
                // view selector. `recv#Src.method(args)` is a direct view method
                // call (ExtMethod); a bare `recv#Src` / `recv#!Src` (or `.field`) is
                // a value re-view (ExtView) the postfix loop continues on. `#!Src`
                // strips the view (the "super" form — a later `.m()` resolves bare).
                p.advance()
                mut val strip: Bool = false
                match p.curKind() {
                    Kind.Bang => {
                        strip = true
                        p.advance()
                    }
                    _ => {}
                }
                val srcTok: Tok = p.curTok()
                val src: String = p.text(t: srcTok)
                p.advance()
                mut val isMethodForm: Bool = false
                match p.curKind() {
                    Kind.Dot => {
                        if p.peekKind(off: 1) == <Kind.Ident /> {
                            if p.peekKind(off: 2) == <Kind.LParen /> {
                                isMethodForm = true
                            }
                        }
                    }
                    _ => {}
                }
                if isMethodForm {
                    if strip {
                        // `#!Src.m(...)`: strip the view, then a bare method call.
                        e = <ExprAst.ExtView recv=e src=src strip=true span=<Span start=sStart end=p.prevEnd() /> />
                    } else {
                        p.advance()
                        val nameTok: Tok = p.curTok()
                        val nm: String = p.text(t: nameTok)
                        p.advance()
                        p.advance()
                        val args: Array[ArgAst] = parseCallArgsAst(p: inout p)
                        e = <ExprAst.ExtMethod recv=e src=src name=nm args=args span=<Span start=sStart end=p.prevEnd() /> />
                    }
                } else {
                    e = <ExprAst.ExtView recv=e src=src strip=strip span=<Span start=sStart end=p.prevEnd() /> />
                }
            }
            Kind.LBracket => {
                p.advance()
                val idx: ExprAst = parseExprAst(p: inout p)
                match p.curKind() {
                    Kind.RBracket => { p.advance() }
                    _ => { p.fail(off: p.base + p.curTok().start, msg: "expected ']' to close an index") }
                }
                e = <ExprAst.Index base=e index=idx span=<Span start=sStart end=p.prevEnd() /> />
            }
            Kind.Arrow => {
                p.advance()
                val nameTok: Tok = p.curTok()
                val nm: String = p.text(t: nameTok)
                p.advance()
                e = <ExprAst.Arrow base=e name=nm span=<Span start=sStart end=p.prevEnd() /> />
            }
            Kind.KwAs => {
                p.advance()
                val ty: TypeAst = parseType(p: inout p)
                e = <ExprAst.Cast operand=e ty=ty span=<Span start=sStart end=p.prevEnd() /> />
            }
            Kind.Newline => {
                mut val off: U64 = 1
                while p.peekKind(off: off) == <Kind.Newline /> {
                    off += 1
                }
                if p.peekKind(off: off) == <Kind.Dot /> {
                    p.skipNewlines()
                } else {
                    break
                }
            }
            _ => { break }
        }
    }
    return e
}

fn parseBinAst(p: inout P, minPrec: I64) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    mut val left: ExprAst = parseUnaryAst(p: inout p)
    while true {
        val k: Kind = p.curKind()
        val prec: I64 = binPrecAst(k: k)
        if prec == 0 {
            break
        }
        if prec < minPrec {
            break
        }
        val op: I64 = kindCode(k: k)
        p.advance()
        val right: ExprAst = parseBinAst(p: inout p, minPrec: prec + 1)
        left = <ExprAst.Binary op=op lhs=left rhs=right span=<Span start=sStart end=p.prevEnd() /> />
        // comparison/equality operators are non-associative (spec/12):
        // `a < b < c` / `a == b == c` are syntax errors — require parens.
        if prec == 3 {
            if binPrecAst(k: p.curKind()) == 3 {
                p.fail(off: p.base + p.curTok().start, msg: "comparison operators are non-associative; add parentheses (e.g. `(a < b) && (b < c)`)")
            }
        }
    }
    return left
}

// Parse a full expression. Exported: the entry point for body parsing (and for
// macros that read an expression position).
export fn parseExprAst(p: inout P) -> ExprAst {
    return parseBinAst(p: inout p, minPrec: 1)
}

// ---- patterns ----
// True if the current token begins a bare literal pattern (`0`/`"x"`/`true`/
// `false`/`'c'`/`-1`). Such an arm desugars to a `==` test in lowering (spec/11).
fn patternStartsLiteral(p: inout P) -> Bool {
    match p.curKind() {
        Kind.Int => { return true }
        Kind.Str => { return true }
        Kind.Char => { return true }
        Kind.KwTrue => { return true }
        Kind.KwFalse => { return true }
        Kind.Minus => { return true }
        _ => { return false }
    }
}

// Parse a literal pattern's value: an optional leading `-` then an int, or a
// string / bool / char literal. Restricted (not a full expression) so a pattern
// can only be a literal, never an arbitrary computation.
fn parsePatternLiteralAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    match p.curKind() {
        Kind.Minus => {
            p.advance()
            val o: ExprAst = parsePrimaryAst(p: inout p)
            return <ExprAst.Unary op=57 operand=o span=<Span start=sStart end=p.prevEnd() /> />
        }
        _ => { return parsePrimaryAst(p: inout p) }
    }
}

fn parsePatternAst(p: inout P) -> PatternAst {
    val sStart: U64 = p.base + p.curTok().start
    val firstTok: Tok = p.curTok()
    mut val isWildcard: Bool = false
    mut val isStruct: Bool = false
    mut val typeName: String = ""
    mut val variant: String = ""
    mut val binds: Array[BindAst] = []
    if patternStartsLiteral(p: inout p) {
        val lit: ExprAst = parsePatternLiteralAst(p: inout p)
        return <PatternAst isWildcard=false isStruct=false typeName="" variant="" binds=binds isLiteral=true lit=lit span=<Span start=sStart end=p.prevEnd() /> />
    }
    // a capture binding `val x`: a named wildcard binding the scrutinee to `x` (spec/11).
    match p.curKind() {
        Kind.KwVal => {
            p.advance()
            val nameTok: Tok = p.curTok()
            val cn: String = p.text(t: nameTok)
            p.advance()
            return <PatternAst isWildcard=true isStruct=false typeName="" variant="" binds=binds captureName=cn span=<Span start=sStart end=p.prevEnd() /> />
        }
        _ => {}
    }
    if rangeEquals(bytes: p.bytes, start: firstTok.start, len: firstTok.len, kw: "_") {
        isWildcard = true
        p.advance()
    } else {
        typeName = p.text(t: firstTok)
        p.advance()
        mut val popen: Bool = false
        match p.curKind() {
            Kind.Dot => {
                p.advance()
                variant = p.text(t: p.curTok())
                p.advance()
                match p.curKind() {
                    Kind.LParen => {
                        p.advance()
                        popen = true
                    }
                    _ => {}
                }
            }
            Kind.LBrace => {
                isStruct = true
                p.advance()
                popen = true
            }
            _ => {}
        }
        if popen {
            while true {
                p.skipNewlines()
                match p.curKind() {
                    Kind.RParen => {
                        p.advance()
                        break
                    }
                    Kind.RBrace => {
                        p.advance()
                        break
                    }
                    Kind.Eof => { break }
                    Kind.KwVal => {
                        p.advance()
                        val bTok: Tok = p.curTok()
                        val bn: String = p.text(t: bTok)
                        val bStart: U64 = p.base + bTok.start
                        p.advance()
                        binds.append(<BindAst field=bn name=bn span=<Span start=bStart end=p.prevEnd() /> />)
                        match p.curKind() {
                            Kind.Comma => { p.advance() }
                            _ => {}
                        }
                    }
                    Kind.Ident => {
                        val fTok: Tok = p.curTok()
                        val fname: String = p.text(t: fTok)
                        val bStart: U64 = p.base + fTok.start
                        p.advance()
                        match p.curKind() {
                            Kind.Colon => { p.advance() }
                            _ => {}
                        }
                        match p.curKind() {
                            Kind.KwVal => {
                                p.advance()
                                val nm: String = p.text(t: p.curTok())
                                p.advance()
                                binds.append(<BindAst field=fname name=nm span=<Span start=bStart end=p.prevEnd() /> />)
                            }
                            _ => {
                                // `field: _` discard — record it (empty bind name) so the
                                // completeness check sees the field as covered without
                                // creating a local for it (struct/variant destructure must
                                // bind OR discard every field — spec/05,11). Anything other
                                // than `_` here (a nested pattern `field: Point(...)`) is a
                                // clean error: Plew patterns are single-level — bind the
                                // field then `match` on the binding (spec/11).
                                val dTok: Tok = p.curTok()
                                if rangeEquals(bytes: p.bytes, start: dTok.start, len: dTok.len, kw: "_") {
                                    binds.append(<BindAst field=fname name="" span=<Span start=bStart end=p.prevEnd() /> />)
                                    p.advance()
                                } else {
                                    p.fail(off: p.base + dTok.start, msg: "a pattern field binds with `val name` or discards with `_`; patterns are single-level — to match a nested structure, bind the field then `match` on the binding (spec/11)")
                                    p.advance()
                                }
                            }
                        }
                        match p.curKind() {
                            Kind.Comma => { p.advance() }
                            _ => {}
                        }
                    }
                    _ => { p.advance() }
                }
            }
        }
    }
    return <PatternAst isWildcard=isWildcard isStruct=isStruct typeName=typeName variant=variant binds=binds span=<Span start=sStart end=p.prevEnd() /> />
}

// Parse an arm's `Pat ( | Pat )*` and consume the `=>`. Returns one PatternAst per
// alternative (the caller shares the body across them). `match` arms have no guards
// (spec/11), so an `if` here is a clean error pointing at the alternatives.
fn parseArmPatternsAst(p: inout P) -> Array[PatternAst] {
    mut val pats: Array[PatternAst] = []
    pats.append(parsePatternAst(p: inout p))
    while true {
        match p.curKind() {
            Kind.Pipe => {
                p.advance()
                p.skipNewlines()
                pats.append(parsePatternAst(p: inout p))
            }
            _ => { break }
        }
    }
    match p.curKind() {
        Kind.KwIf => {
            p.fail(off: p.base + p.curTok().start, msg: "`match` arms have no guards (spec/11): refine with a nested `match`, or a preceding `if`/`guard` condition chain")
        }
        _ => {}
    }
    match p.curKind() {
        Kind.FatArrow => { p.advance() }
        _ => {}
    }
    return pats
}

// A statement-position match-arm body: a `{ }` block or a single bare statement
// wrapped into a one-statement block.
fn parseArmBodyAst(p: inout P) -> BlockAst {
    match p.curKind() {
        Kind.LBrace => { return parseBlockAst(p: inout p) }
        _ => {
            mut val stmts: Array[StmtAst] = []
            stmts.append(parseStmtAst(p: inout p))
            return <BlockAst stmts=stmts />
        }
    }
}

fn parseMatchStmtAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val scrut: ExprAst = parseExprAst(p: inout p)
    p.skipNewlines()
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val arms: Array[MatchArmAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            _ => {
                val armStart: U64 = p.base + p.curTok().start
                val pats: Array[PatternAst] = parseArmPatternsAst(p: inout p)
                p.skipNewlines()
                val body: BlockAst = parseArmBodyAst(p: inout p)
                mut val pi: U64 = 0
                while pi < pats.count {
                    arms.append(<MatchArmAst pattern=pats[pi] body=body span=<Span start=armStart end=p.prevEnd() /> />)
                    pi += 1
                }
            }
        }
    }
    return <StmtAst.Match scrut=scrut arms=arms span=<Span start=sStart end=p.prevEnd() /> />
}

// A value-position match-arm body. A bare expression `=> e` becomes a one-`give`
// block; a diverging arm `=> panic …` / `=> return …` becomes a one-statement
// block (no give); a `{ }` block is taken as-is (it ends in `give` or diverges).
// The lowering distinguishes value vs diverging arms by the terminal statement.
fn parseExprArmBodyAst(p: inout P, armStart: U64) -> BlockAst {
    match p.curKind() {
        Kind.LBrace => { return parseBlockAst(p: inout p) }
        Kind.KwReturn => {
            mut val one: Array[StmtAst] = []
            one.append(parseStmtAst(p: inout p))
            return <BlockAst stmts=one />
        }
        Kind.Ident => {
            if curIs(p: inout p, kw: "panic") {
                mut val one: Array[StmtAst] = []
                one.append(parsePanicAst(p: inout p))
                return <BlockAst stmts=one />
            }
            val e: ExprAst = parseExprAst(p: inout p)
            mut val g: Array[StmtAst] = []
            g.append(<StmtAst.Give value=e span=<Span start=armStart end=p.prevEnd() /> />)
            return <BlockAst stmts=g />
        }
        _ => {
            val e: ExprAst = parseExprAst(p: inout p)
            mut val g: Array[StmtAst] = []
            g.append(<StmtAst.Give value=e span=<Span start=armStart end=p.prevEnd() /> />)
            return <BlockAst stmts=g />
        }
    }
}

fn parseMatchExprAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val scrut: ExprAst = parseExprAst(p: inout p)
    p.skipNewlines()
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val arms: Array[MatchArmAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            _ => {
                val armStart: U64 = p.base + p.curTok().start
                val pats: Array[PatternAst] = parseArmPatternsAst(p: inout p)
                val body: BlockAst = parseExprArmBodyAst(p: inout p, armStart: armStart)
                mut val pi: U64 = 0
                while pi < pats.count {
                    arms.append(<MatchArmAst pattern=pats[pi] body=body span=<Span start=armStart end=p.prevEnd() /> />)
                    pi += 1
                }
                match p.curKind() {
                    Kind.Comma => { p.advance() }
                    _ => {}
                }
            }
        }
    }
    return <ExprAst.MatchExpr scrut=scrut arms=arms span=<Span start=sStart end=p.prevEnd() /> />
}

// ---- statements ----
fn parseLetAst(p: inout P, mutable: Bool) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val nm: String = p.text(t: p.curTok())
    p.advance()
    mut val hasTy: Bool = false
    mut val ty: TypeAst = emptyTypeAst()
    match p.curKind() {
        Kind.Colon => {
            p.advance()
            ty = parseType(p: inout p)
            hasTy = true
        }
        _ => {}
    }
    match p.curKind() {
        Kind.Eq => { p.advance() }
        _ => { p.fail(off: p.base + p.curTok().start, msg: "expected '=' — a variable declaration must be initialized") }
    }
    val init: ExprAst = parseExprAst(p: inout p)
    return <StmtAst.Let mutable=mutable name=nm hasTy=hasTy ty=ty init=init span=<Span start=sStart end=p.prevEnd() /> />
}

fn parseReturnAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    match p.curKind() {
        Kind.Newline => { return <StmtAst.Return value=emptyExpr() hasValue=false span=<Span start=sStart end=p.prevEnd() /> /> }
        Kind.RBrace => { return <StmtAst.Return value=emptyExpr() hasValue=false span=<Span start=sStart end=p.prevEnd() /> /> }
        Kind.Eof => { return <StmtAst.Return value=emptyExpr() hasValue=false span=<Span start=sStart end=p.prevEnd() /> /> }
        _ => {
            val e: ExprAst = parseExprAst(p: inout p)
            return <StmtAst.Return value=e hasValue=true span=<Span start=sStart end=p.prevEnd() /> />
        }
    }
}

// True if the if/while/guard condition is a refutable binding `PATTERN = expr` (vs a
// Bool expression — spec/11 condition chain). Backtracks: tries to parse a pattern and
// checks for a single `=` (not `==`); restores the cursor and error state.
fn detectRefutableBinding(p: inout P) -> Bool {
    val savedPos: U64 = p.pos
    val savedErr: Bool = p.hasErr
    parsePatternAst(p: inout p)
    mut val isBind: Bool = false
    match p.curKind() {
        Kind.Eq => { isBind = true }
        _ => {}
    }
    p.pos = savedPos
    p.hasErr = savedErr
    return isBind
}

// Whether the condition is a chain `clause (&& clause)*` containing a refutable
// binding in ANY clause — not just the first (spec/11: `flag && val x = opt`). Drives
// the if/while dispatch to the cond-chain desugar; a pure-Bool condition (no binding)
// returns false and keeps the plain-expression path (which also handles `||`). A
// speculative scan: `&&`-split the chain, restore on exit.
fn condChainHasBinding(p: inout P) -> Bool {
    val savedPos: U64 = p.pos
    val savedErr: Bool = p.hasErr
    mut val found: Bool = false
    while true {
        if detectRefutableBinding(p: inout p) {
            found = true
            break
        }
        // not this clause — skip the Bool expression (stops before `&&`/`||`) and only
        // continue across a top-level `&&` (bindings are `&&`-joined; `||` ends the scan).
        parseBinAst(p: inout p, minPrec: 3)
        match p.curKind() {
            Kind.AmpAmp => { p.advance() }
            _ => { break }
        }
    }
    p.pos = savedPos
    p.hasErr = savedErr
    return found
}

// Parse `else { … }` / `else if …` after an if/if-let body. Returns the else block
// (an empty block when there is no `else`).
fn parseElseBlockAst(p: inout P) -> BlockAst {
    match p.curKind() {
        Kind.KwElse => {
            p.advance()
            match p.curKind() {
                Kind.KwIf => {
                    mut val one: Array[StmtAst] = []
                    one.append(parseIfStmtAst(p: inout p))
                    return <BlockAst stmts=one />
                }
                _ => { return parseBlockAst(p: inout p) }
            }
        }
        _ => {}
    }
    return emptyBlock()
}

// One clause of a condition chain (spec/11): a refutable binding `PATTERN = expr`, or
// a Bool expression.
struct CondClause {
    pub val isBinding: Bool
    pub val pattern: PatternAst
    pub val expr: ExprAst
}

// Parse one chain clause: a refutable binding `PATTERN = expr`, or a Bool expression
// (parsed up to the next top-level `&&`; `||` must be parenthesized — spec/11).
fn parseCondClause(p: inout P) -> CondClause {
    val dummy: Span = <Span start=0 end=0 />
    if detectRefutableBinding(p: inout p) {
        val pat: PatternAst = parsePatternAst(p: inout p)
        match p.curKind() {
            Kind.Eq => { p.advance() }
            _ => {}
        }
        return <CondClause isBinding=true pattern=pat expr=parseBinAst(p: inout p, minPrec: 3) />
    }
    return <CondClause isBinding=false pattern=<PatternAst isWildcard=true isStruct=false typeName="" variant="" binds=[] span=dummy /> expr=parseBinAst(p: inout p, minPrec: 3) />
}

// Parse a condition chain `clause (&& clause)*` (the first clause is a binding — the
// caller dispatched plain-Bool conditions already).
fn parseCondChain(p: inout P) -> Array[CondClause] {
    mut val clauses: Array[CondClause] = []
    clauses.append(parseCondClause(p: inout p))
    while true {
        match p.curKind() {
            Kind.AmpAmp => {
                p.advance()
                clauses.append(parseCondClause(p: inout p))
            }
            _ => { break }
        }
    }
    return clauses
}

// Build the statement form of a condition chain: each binding clause becomes a `match`
// (pattern arm runs the inner chain, wildcard arm runs `elseBlk`), each Bool clause an
// `if … else elseBlk`. The innermost (after the last clause) runs `thenBlk`.
fn buildCondChainStmt(clauses: Array[CondClause], idx: U64, thenBlk: BlockAst, elseBlk: BlockAst, span: Span) -> StmtAst {
    val clause: CondClause = clauses[idx]
    mut val inner: BlockAst = thenBlk
    if idx + 1U64 < clauses.count {
        mut val one: Array[StmtAst] = []
        one.append(buildCondChainStmt(clauses: clauses, idx: idx + 1U64, thenBlk: thenBlk, elseBlk: elseBlk, span: span))
        inner = <BlockAst stmts=one />
    }
    if clause.isBinding {
        mut val arms: Array[MatchArmAst] = []
        arms.append(<MatchArmAst pattern=clause.pattern body=inner span=span />)
        arms.append(<MatchArmAst pattern=<PatternAst isWildcard=true isStruct=false typeName="" variant="" binds=[] span=span /> body=elseBlk span=span />)
        return <StmtAst.Match scrut=clause.expr arms=arms span=span />
    }
    return <StmtAst.If cond=clause.expr thenBlk=inner elseBlk=elseBlk hasElse=true span=span />
}

// Build the value (expression) form of a condition chain: binding clauses become a
// value `match`, Bool clauses a value `if`. `thenBlk`/`elseBlk` end in `give`.
fn buildCondChainExpr(clauses: Array[CondClause], idx: U64, thenBlk: BlockAst, elseBlk: BlockAst, span: Span) -> ExprAst {
    val clause: CondClause = clauses[idx]
    mut val inner: BlockAst = thenBlk
    if idx + 1U64 < clauses.count {
        val innerExpr: ExprAst = buildCondChainExpr(clauses: clauses, idx: idx + 1U64, thenBlk: thenBlk, elseBlk: elseBlk, span: span)
        mut val one: Array[StmtAst] = []
        one.append(<StmtAst.Give value=innerExpr span=span />)
        inner = <BlockAst stmts=one />
    }
    if clause.isBinding {
        mut val arms: Array[MatchArmAst] = []
        arms.append(<MatchArmAst pattern=clause.pattern body=inner span=span />)
        arms.append(<MatchArmAst pattern=<PatternAst isWildcard=true isStruct=false typeName="" variant="" binds=[] span=span /> body=elseBlk span=span />)
        return <ExprAst.MatchExpr scrut=clause.expr arms=arms span=span />
    }
    return <ExprAst.IfExpr cond=clause.expr thenBlk=inner elseBlk=elseBlk span=span />
}

// Parse an `if`-let statement `if <cond-chain> { then } [else { els }]` (spec/11). The
// chain `&&`-joins refutable bindings and Bool clauses; bindings scope to `then`.
fn parseIfLetStmt(p: inout P, sStart: U64) -> StmtAst {
    val clauses: Array[CondClause] = parseCondChain(p: inout p)
    val thenBlk: BlockAst = parseBlockAst(p: inout p)
    p.skipNewlines()
    val elseBlk: BlockAst = parseElseBlockAst(p: inout p)
    return buildCondChainStmt(clauses: clauses, idx: 0U64, thenBlk: thenBlk, elseBlk: elseBlk, span: <Span start=sStart end=p.prevEnd() />)
}

fn parseIfStmtAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    if condChainHasBinding(p: inout p) {
        return parseIfLetStmt(p: inout p, sStart: sStart)
    }
    val cond: ExprAst = parseExprAst(p: inout p)
    val thenBlk: BlockAst = parseBlockAst(p: inout p)
    p.skipNewlines()
    match p.curKind() {
        Kind.KwElse => {
            p.advance()
            match p.curKind() {
                Kind.KwIf => {
                    val nested: StmtAst = parseIfStmtAst(p: inout p)
                    mut val one: Array[StmtAst] = []
                    one.append(nested)
                    return <StmtAst.If cond=cond thenBlk=thenBlk elseBlk=<BlockAst stmts=one /> hasElse=true span=<Span start=sStart end=p.prevEnd() /> />
                }
                _ => {
                    val elseBlk: BlockAst = parseBlockAst(p: inout p)
                    return <StmtAst.If cond=cond thenBlk=thenBlk elseBlk=elseBlk hasElse=true span=<Span start=sStart end=p.prevEnd() /> />
                }
            }
        }
        _ => {
            return <StmtAst.If cond=cond thenBlk=thenBlk elseBlk=emptyBlock() hasElse=false span=<Span start=sStart end=p.prevEnd() /> />
        }
    }
}

// Value-position `if`-let `if PATTERN = expr [&& cond] { give a } else { give b }`
// (spec/11): desugars to a value-position `match` over `expr`. `else` is mandatory in
// value position (both branches must yield).
fn parseIfLetExpr(p: inout P, sStart: U64) -> ExprAst {
    val clauses: Array[CondClause] = parseCondChain(p: inout p)
    val thenBlk: BlockAst = parseBlockAst(p: inout p)
    p.skipNewlines()
    match p.curKind() {
        Kind.KwElse => { p.advance() }
        _ => {}
    }
    val elseBlk: BlockAst = parseBlockAst(p: inout p)
    return buildCondChainExpr(clauses: clauses, idx: 0U64, thenBlk: thenBlk, elseBlk: elseBlk, span: <Span start=sStart end=p.prevEnd() />)
}

fn parseIfExprAst(p: inout P) -> ExprAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    if condChainHasBinding(p: inout p) {
        return parseIfLetExpr(p: inout p, sStart: sStart)
    }
    val cond: ExprAst = parseExprAst(p: inout p)
    val thenBlk: BlockAst = parseBlockAst(p: inout p)
    p.skipNewlines()
    match p.curKind() {
        Kind.KwElse => { p.advance() }
        _ => {}
    }
    match p.curKind() {
        Kind.KwIf => {
            val nested: ExprAst = parseIfExprAst(p: inout p)
            mut val one: Array[StmtAst] = []
            one.append(<StmtAst.Give value=nested span=<Span start=sStart end=p.prevEnd() /> />)
            return <ExprAst.IfExpr cond=cond thenBlk=thenBlk elseBlk=<BlockAst stmts=one /> span=<Span start=sStart end=p.prevEnd() /> />
        }
        _ => {
            val elseBlk: BlockAst = parseBlockAst(p: inout p)
            return <ExprAst.IfExpr cond=cond thenBlk=thenBlk elseBlk=elseBlk span=<Span start=sStart end=p.prevEnd() /> />
        }
    }
}

fn parseWhileAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    if condChainHasBinding(p: inout p) {
        return parseWhileLetStmt(p: inout p, sStart: sStart)
    }
    val cond: ExprAst = parseExprAst(p: inout p)
    val body: BlockAst = parseBlockAst(p: inout p)
    return <StmtAst.While cond=cond body=body span=<Span start=sStart end=p.prevEnd() /> />
}

// Parse a `while`-let statement `while <cond-chain> { body }` (spec/11 `while let`).
// Desugars to `while true { <chain over body / break> }`: each iteration re-evaluates
// the chain; a failed binding (or false Bool clause) breaks the loop.
fn parseWhileLetStmt(p: inout P, sStart: U64) -> StmtAst {
    val clauses: Array[CondClause] = parseCondChain(p: inout p)
    val body: BlockAst = parseBlockAst(p: inout p)
    val span: Span = <Span start=sStart end=p.prevEnd() />
    mut val breakStmts: Array[StmtAst] = []
    breakStmts.append(<StmtAst.Break span=span />)
    val breakBlk: BlockAst = <BlockAst stmts=breakStmts />
    mut val loopStmts: Array[StmtAst] = []
    loopStmts.append(buildCondChainStmt(clauses: clauses, idx: 0U64, thenBlk: body, elseBlk: breakBlk, span: span))
    val trueLit: ExprAst = <ExprAst.IntLit value=1 isBool=true tySuffix="" span=span />
    return <StmtAst.While cond=trueLit body=<BlockAst stmts=loopStmts /> span=span />
}

fn parseForAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    mut val isStruct: Bool = false
    mut val patType: String = ""
    mut val binds: Array[BindAst] = []
    mut val varName: String = ""
    mut val varTy: TypeAst = emptyTypeAst()
    mut val hasVarTy: Bool = false
    mut val isPattern: Bool = false
    // a record-destructuring loop pattern `for (val x, val y) in xs` (spec/02,11):
    // desugar to `for val __fe in xs { (val x, val y) = __fe; <body> }`, reusing the
    // statement-level record destructuring. Detected by `(` then `val` / `ident : val`.
    mut val isRecordPat: Bool = false
    match p.curKind() {
        Kind.LParen => {
            if p.peekKind(off: 1) == <Kind.KwVal /> {
                isRecordPat = true
            }
            if p.peekKind(off: 1) == <Kind.Ident /> {
                if p.peekKind(off: 2) == <Kind.Colon /> {
                    if p.peekKind(off: 3) == <Kind.KwVal /> {
                        isRecordPat = true
                    }
                }
            }
        }
        _ => {}
    }
    if isRecordPat {
        p.advance()
        mut val recBinds: Array[BindAst] = []
        while true {
            match p.curKind() {
                Kind.RParen => { p.advance()  break }
                Kind.Eof => { break }
                Kind.Comma => { p.advance() }
                _ => {
                    mut val field: String = ""
                    val bStart: U64 = p.base + p.curTok().start
                    match p.curKind() {
                        Kind.Ident => {
                            field = p.text(t: p.curTok())
                            p.advance()
                            match p.curKind() {
                                Kind.Colon => { p.advance() }
                                _ => { p.fail(off: p.base + p.curTok().start, msg: "a record loop-pattern field is `label: val name` or punned `val name`") }
                            }
                        }
                        _ => {}
                    }
                    match p.curKind() {
                        Kind.KwVal => { p.advance() }
                        _ => { p.fail(off: p.base + p.curTok().start, msg: "a record loop pattern needs `val name`") }
                    }
                    val nameTok: Tok = p.curTok()
                    val nm: String = p.text(t: nameTok)
                    p.advance()
                    if field.bytes().count == 0U64 {
                        field = nm
                    }
                    recBinds.append(<BindAst field=field name=nm span=<Span start=bStart end=p.prevEnd() /> />)
                }
            }
        }
        match p.curKind() {
            Kind.KwIn => { p.advance() }
            _ => {}
        }
        val rlo: ExprAst = parseExprAst(p: inout p)
        p.skipNewlines()
        val rbody: BlockAst = parseBlockAst(p: inout p)
        // a record loop pattern: marked `patType="__rec__"` with the field binds. The
        // frontend lowering binds a fresh element local and prepends a field-by-field
        // destructuring to the body (arena-level, so the synthetic names are interned —
        // an AST-level synthetic `Ident` would re-read the source by span and break).
        return <StmtAst.For varName="" varTy=emptyTypeAst() hasVarTy=false isRange=false inclusive=false iter=rlo rangeHi=emptyExpr() body=rbody isStruct=false patType="__rec__" binds=recBinds span=<Span start=sStart end=p.prevEnd() /> />
    }
    match p.curKind() {
        Kind.Ident => {
            if p.peekKind(off: 1) == <Kind.LBrace /> {
                isPattern = true
            }
        }
        _ => {}
    }
    if isPattern {
        val pi: PatternAst = parsePatternAst(p: inout p)
        isStruct = pi.isStruct
        patType = pi.typeName
        binds = pi.binds
    } else {
        match p.curKind() {
            Kind.KwVal => { p.advance() }
            _ => {}
        }
        varName = p.text(t: p.curTok())
        p.advance()
        // optional loop-variable type annotation (`for val i: I32 in …`): it types
        // the range bounds / element binding so bare literals need no suffix.
        match p.curKind() {
            Kind.Colon => {
                p.advance()
                varTy = parseType(p: inout p)
                hasVarTy = true
            }
            _ => {}
        }
    }
    match p.curKind() {
        Kind.KwIn => { p.advance() }
        _ => {}
    }
    val lo: ExprAst = parseExprAst(p: inout p)
    mut val isRange: Bool = false
    mut val inclusive: Bool = false
    mut val hi: ExprAst = emptyExpr()
    match p.curKind() {
        Kind.DotDotLt => {
            p.advance()
            isRange = true
            hi = parseExprAst(p: inout p)
        }
        Kind.DotDotEq => {
            p.advance()
            isRange = true
            inclusive = true
            hi = parseExprAst(p: inout p)
        }
        _ => {}
    }
    p.skipNewlines()
    val body: BlockAst = parseBlockAst(p: inout p)
    return <StmtAst.For varName=varName varTy=varTy hasVarTy=hasVarTy isRange=isRange inclusive=inclusive iter=lo rangeHi=hi body=body isStruct=isStruct patType=patType binds=binds span=<Span start=sStart end=p.prevEnd() /> />
}

fn parsePanicAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val msg: ExprAst = parseExprAst(p: inout p)
    return <StmtAst.Panic msg=msg span=<Span start=sStart end=p.prevEnd() /> />
}

fn parseGiveAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    val v: ExprAst = parseExprAst(p: inout p)
    return <StmtAst.Give value=v span=<Span start=sStart end=p.prevEnd() /> />
}

fn parseExprOrAssignAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    val lhs: ExprAst = parseExprAst(p: inout p)
    val k: Kind = p.curKind()
    if isAssignOpAst(k: k) {
        val op: I64 = kindCode(k: k)
        p.advance()
        val rhs: ExprAst = parseExprAst(p: inout p)
        return <StmtAst.Assign op=op target=lhs value=rhs span=<Span start=sStart end=p.prevEnd() /> />
    }
    return <StmtAst.ExprStmt expr=lhs span=<Span start=sStart end=p.prevEnd() /> />
}

fn parseStmtAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    match p.curKind() {
        Kind.KwVal => { return parseLetAst(p: inout p, mutable: false) }
        Kind.KwMut => {
            p.advance()
            return parseLetAst(p: inout p, mutable: true)
        }
        Kind.KwIf => { return parseIfStmtAst(p: inout p) }
        Kind.KwWhile => { return parseWhileAst(p: inout p) }
        Kind.KwFor => { return parseForAst(p: inout p) }
        Kind.KwMatch => { return parseMatchStmtAst(p: inout p) }
        Kind.KwBreak => {
            p.advance()
            return <StmtAst.Break span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.KwContinue => {
            p.advance()
            return <StmtAst.Continue span=<Span start=sStart end=p.prevEnd() /> />
        }
        Kind.KwReturn => { return parseReturnAst(p: inout p) }
        Kind.KwGive => { return parseGiveAst(p: inout p) }
        Kind.Ident => {
            if curIs(p: inout p, kw: "panic") {
                return parsePanicAst(p: inout p)
            }
            return parseExprOrAssignAst(p: inout p)
        }
        Kind.LParen => {
            // record destructuring `(val x, val y) = e` / `(a: val x) = e` (spec/02,03):
            // a `(` whose first element binds (`val` punned, or `label : val`). Anything
            // else starting with `(` is a parenthesized expression statement.
            mut val isDestructure: Bool = false
            if p.peekKind(off: 1) == <Kind.KwVal /> {
                isDestructure = true
            }
            if p.peekKind(off: 1) == <Kind.Ident /> {
                if p.peekKind(off: 2) == <Kind.Colon /> {
                    if p.peekKind(off: 3) == <Kind.KwVal /> {
                        isDestructure = true
                    }
                }
            }
            if isDestructure {
                return parseDestructureAst(p: inout p)
            }
            return parseExprOrAssignAst(p: inout p)
        }
        _ => { return parseExprOrAssignAst(p: inout p) }
    }
}

// Parse a record-destructuring statement `(val x, val y) = e` / `(a: val x, …) = e`.
fn parseDestructureAst(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    mut val binds: Array[BindAst] = []
    while true {
        match p.curKind() {
            Kind.RParen => { p.advance()  break }
            Kind.Eof => { break }
            Kind.Comma => { p.advance() }
            _ => {
                mut val field: String = ""
                val bStart: U64 = p.base + p.curTok().start
                // explicit `label: val name`, or punned `val name`.
                match p.curKind() {
                    Kind.Ident => {
                        field = p.text(t: p.curTok())
                        p.advance()
                        match p.curKind() {
                            Kind.Colon => { p.advance() }
                            _ => { p.fail(off: p.base + p.curTok().start, msg: "a record-destructuring field is `label: val name` or punned `val name`") }
                        }
                    }
                    _ => {}
                }
                match p.curKind() {
                    Kind.KwVal => { p.advance() }
                    _ => { p.fail(off: p.base + p.curTok().start, msg: "a record-destructuring binding needs `val name`") }
                }
                val nameTok: Tok = p.curTok()
                val name: String = p.text(t: nameTok)
                p.advance()
                if field.bytes().count == 0U64 {
                    field = name
                }
                binds.append(<BindAst field=field name=name span=<Span start=bStart end=p.prevEnd() /> />)
            }
        }
    }
    match p.curKind() {
        Kind.Eq => { p.advance() }
        _ => { p.fail(off: p.base + p.curTok().start, msg: "record destructuring must be initialized: `(val x, val y) = expr`") }
    }
    val init: ExprAst = parseExprAst(p: inout p)
    return <StmtAst.Destructure binds=binds init=init span=<Span start=sStart end=p.prevEnd() /> />
}

// Parse `{ stmt* }` into a BlockAst. Current token should be `{`. Exported for the
// frontend lowering and for macros that read a body.
// Parse the remaining statements of a block up to (but NOT consuming) the closing
// `}` — the "continuation" a `guard` wraps. A nested `guard` consumes the rest itself.
fn parseStmtsUntilBrace(p: inout P) -> Array[StmtAst] {
    mut val stmts: Array[StmtAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => { break }
            Kind.Eof => { break }
            _ => {
                if curIs(p: inout p, kw: "guard") {
                    stmts.append(parseGuardStmt(p: inout p))
                    break
                }
                stmts.append(parseStmtAst(p: inout p))
            }
        }
    }
    return stmts
}

// Whether a block unconditionally diverges (its last statement transfers control out:
// return / panic / break / continue, or an if/match all of whose branches diverge).
// Used to enforce that a `guard` else block diverges (spec/11). A structural, AST-level
// check (the guard's "marker" is lost once it desugars to if/match).
fn blockDivergesAst(b: BlockAst) -> Bool {
    if b.stmts.count == 0U64 {
        return false
    }
    return stmtDivergesAst(s: b.stmts[b.stmts.count - 1U64])
}

fn stmtDivergesAst(s: StmtAst) -> Bool {
    match s {
        StmtAst.Return(value: _, hasValue: _, span: _) => { return true }
        StmtAst.Panic(msg: _, span: _) => { return true }
        StmtAst.Break(span: _) => { return true }
        StmtAst.Continue(span: _) => { return true }
        StmtAst.If(cond: _, val thenBlk, val elseBlk, val hasElse, span: _) => {
            if hasElse {
                if blockDivergesAst(b: thenBlk) {
                    return blockDivergesAst(b: elseBlk)
                }
            }
            return false
        }
        StmtAst.Match(scrut: _, val arms, span: _) => {
            mut val i: U64 = 0
            while i < arms.count {
                if !(blockDivergesAst(b: arms[i].body)) {
                    return false
                }
                i += 1
            }
            return arms.count > 0U64
        }
        _ => { return false }
    }
}

// Parse a `guard` statement (spec/11): `guard <cond-chain> { elseBody } <rest>`. The
// elseBody runs when the condition FAILS and MUST diverge (return / break / continue /
// panic — spec/11); the `<rest>` of the enclosing block runs (with any bindings in
// scope) only on success. Desugars by wrapping the rest in the success branch — so
// bindings naturally escape to it:
//   guard cond { e } rest       -> if cond { rest } else { e }
//   guard P = expr { e } rest   -> match expr { P => { rest }  _ => { e } }
// (Trailing `&& cond` clauses gate the success branch.)
fn parseGuardStmt(p: inout P) -> StmtAst {
    val sStart: U64 = p.base + p.curTok().start
    p.advance()
    if condChainHasBinding(p: inout p) {
        val clauses: Array[CondClause] = parseCondChain(p: inout p)
        val elseOff: U64 = p.base + p.curTok().start
        val elseBody: BlockAst = parseBlockAst(p: inout p)
        checkGuardElseDiverges(p: inout p, elseBody: elseBody, off: elseOff)
        p.skipNewlines()
        val cont: Array[StmtAst] = parseStmtsUntilBrace(p: inout p)
        val span: Span = <Span start=sStart end=p.prevEnd() />
        // the continuation is the success branch (bindings escape into it).
        return buildCondChainStmt(clauses: clauses, idx: 0U64, thenBlk: <BlockAst stmts=cont />, elseBlk: elseBody, span: span)
    }
    val cond: ExprAst = parseExprAst(p: inout p)
    val elseOff: U64 = p.base + p.curTok().start
    val elseBody: BlockAst = parseBlockAst(p: inout p)
    checkGuardElseDiverges(p: inout p, elseBody: elseBody, off: elseOff)
    p.skipNewlines()
    val cont: Array[StmtAst] = parseStmtsUntilBrace(p: inout p)
    val span: Span = <Span start=sStart end=p.prevEnd() />
    return <StmtAst.If cond=cond thenBlk=<BlockAst stmts=cont /> elseBlk=elseBody hasElse=true span=span />
}

// Loud error if a `guard` else block can fall through (spec/11: it must diverge).
fn checkGuardElseDiverges(p: inout P, elseBody: BlockAst, off: U64) {
    if !(blockDivergesAst(b: elseBody)) {
        p.fail(off: off, msg: "`guard` else block must diverge (end in return / break / continue / panic) — spec/11")
    }
}

export fn parseBlockAst(p: inout P) -> BlockAst {
    match p.curKind() {
        Kind.LBrace => { p.advance() }
        _ => {}
    }
    mut val stmts: Array[StmtAst] = []
    while true {
        p.skipNewlines()
        match p.curKind() {
            Kind.RBrace => {
                p.advance()
                break
            }
            Kind.Eof => { break }
            _ => {
                if curIs(p: inout p, kw: "guard") {
                    stmts.append(parseGuardStmt(p: inout p))
                } else {
                    stmts.append(parseStmtAst(p: inout p))
                }
            }
        }
    }
    return <BlockAst stmts=stmts />
}

// ---- convenience entry points (build the cursor internally) ----
//
// The P cursor is module-private; these let callers (the frontend lowering, macros,
// tests) parse from source text. `source` is the text; `start` is its absolute
// offset in the original file (the span base, for original coordinates).
// Lex `source` and parse a single expression.
export fn parseExprFrom(source: String, start: U64) -> ExprAst {
    val sb: Array[U8] = source.bytes()
    mut val lx: Lexer = <Lexer bytes=sb pos=0 toks=[] depth=0 />
    lex(lx: inout lx)
    mut val p: P = <P bytes=sb toks=lx.toks pos=0 base=start />
    return parseExprAst(p: inout p)
}

// Lex `source` and parse a brace-delimited block `{ ... }`.
export fn parseBlockFrom(source: String, start: U64) -> BlockAst {
    val sb: Array[U8] = source.bytes()
    mut val lx: Lexer = <Lexer bytes=sb pos=0 toks=[] depth=0 />
    lex(lx: inout lx)
    mut val p: P = <P bytes=sb toks=lx.toks pos=0 base=start />
    return parseBlockAst(p: inout p)
}

export struct Src {
    pub mut val bytes: Array[U8]
}

// A fresh, empty source builder.
export fn newSrc() -> Src {
    return <Src bytes=[] />
}

// A decimal digit (0-9) as its ASCII byte. (No implicit U64->U8 narrowing, so the
// glyph table is spelled out, like @Std/Core's internal digit helpers.)
fn srcDigitByte(d: U64) -> U8 {
    if d == 0 { return 48 }
    if d == 1 { return 49 }
    if d == 2 { return 50 }
    if d == 3 { return 51 }
    if d == 4 { return 52 }
    if d == 5 { return 53 }
    if d == 6 { return 54 }
    if d == 7 { return 55 }
    if d == 8 { return 56 }
    return 57
}
